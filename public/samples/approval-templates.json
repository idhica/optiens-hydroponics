{
  "personas": [
    { "id": "tanaka",   "role": "submitter", "name": "田中 一郎", "title": "営業部 担当",     "icon": "fa-user" },
    { "id": "sato",     "role": "approver1", "name": "佐藤 健太", "title": "営業部 部長",     "icon": "fa-user-tie" },
    { "id": "suzuki",   "role": "approver2", "name": "鈴木 美咲", "title": "経理部 マネージャー", "icon": "fa-calculator" },
    { "id": "yamada",   "role": "approver3", "name": "山田 太郎", "title": "代表取締役",     "icon": "fa-crown" }
  ],
  "templates": [
    {
      "id": "expense",
      "title": "経費申請",
      "icon": "fa-receipt",
      "summary": "出張・交際・備品などの経費精算を申請します。金額に応じて承認ルートが自動で変わります。",
      "fields": [
        { "key": "purpose",   "label": "用途",       "type": "text",     "placeholder": "例：取引先訪問の交通費" },
        { "key": "category",  "label": "経費区分",   "type": "select",   "options": ["旅費交通費","会議費","交際費","消耗品費","通信費"] },
        { "key": "amount",    "label": "金額（円）", "type": "number",   "placeholder": "例：80000" },
        { "key": "incurredAt","label": "発生日",     "type": "date" },
        { "key": "memo",      "label": "詳細・備考", "type": "textarea", "placeholder": "出張先・参加者・経緯など" }
      ],
      "rules": [
        { "when": "amount <= 50000",  "route": ["sato"],                       "label": "5万円以下：部長承認のみ" },
        { "when": "amount <= 200000", "route": ["sato", "suzuki"],             "label": "5万円超〜20万円：部長 → 経理" },
        { "when": "amount > 200000",  "route": ["sato", "suzuki", "yamada"],   "label": "20万円超：部長 → 経理 → 代表" }
      ]
    },
    {
      "id": "purchase",
      "title": "購買稟議",
      "icon": "fa-cart-shopping",
      "summary": "備品・ソフトウェア・外注サービスなどの新規購入を稟議します。区分と金額で承認ルートが変わります。",
      "fields": [
        { "key": "itemName",  "label": "購入品目",   "type": "text",     "placeholder": "例：業務用ノートPC（5台）" },
        { "key": "category",  "label": "購買区分",   "type": "select",   "options": ["IT機器","ソフトウェアライセンス","オフィス備品","外注サービス","その他"] },
        { "key": "vendor",    "label": "購入先",     "type": "text",     "placeholder": "例：株式会社○○商会" },
        { "key": "amount",    "label": "金額（円）", "type": "number",   "placeholder": "例：450000" },
        { "key": "reason",    "label": "購入理由",   "type": "textarea", "placeholder": "業務上の必要性・代替案の検討結果など" }
      ],
      "rules": [
        { "when": "amount <= 100000",  "route": ["sato"],                       "label": "10万円以下：部長承認のみ" },
        { "when": "amount <= 500000",  "route": ["sato", "suzuki"],             "label": "10万円超〜50万円：部長 → 経理" },
        { "when": "amount > 500000",   "route": ["sato", "suzuki", "yamada"],   "label": "50万円超：部長 → 経理 → 代表" }
      ]
    },
    {
      "id": "contract",
      "title": "契約書承認",
      "icon": "fa-file-signature",
      "summary": "取引先との契約締結を申請します。契約金額・契約期間に応じて承認ルートが変わります。",
      "fields": [
        { "key": "counterparty","label": "契約相手",     "type": "text",     "placeholder": "例：株式会社○○" },
        { "key": "contractType","label": "契約種別",     "type": "select",   "options": ["業務委託契約","売買契約","賃貸借契約","ライセンス契約","秘密保持契約（NDA）"] },
        { "key": "amount",      "label": "契約金額（円）","type": "number",   "placeholder": "例：1200000" },
        { "key": "termMonths",  "label": "契約期間（月）","type": "number",   "placeholder": "例：12" },
        { "key": "summary",     "label": "契約概要",     "type": "textarea", "placeholder": "契約の目的・主要条件・特記事項など" }
      ],
      "rules": [
        { "when": "amount <= 300000",  "route": ["sato"],                       "label": "30万円以下：部長承認のみ" },
        { "when": "amount <= 1000000", "route": ["sato", "suzuki"],             "label": "30万円超〜100万円：部長 → 経理" },
        { "when": "amount > 1000000",  "route": ["sato", "suzuki", "yamada"],   "label": "100万円超：部長 → 経理 → 代表" }
      ]
    },
    {
      "id": "leave",
      "title": "休暇届",
      "icon": "fa-umbrella-beach",
      "summary": "有給休暇・特別休暇などの取得を申請します。期間が長い場合は経理の承認も必要です。",
      "fields": [
        { "key": "leaveType", "label": "休暇種別",   "type": "select",   "options": ["有給休暇","特別休暇","慶弔休暇","代休","その他"] },
        { "key": "startDate", "label": "開始日",     "type": "date" },
        { "key": "endDate",   "label": "終了日",     "type": "date" },
        { "key": "days",      "label": "取得日数",   "type": "number",   "placeholder": "例：3" },
        { "key": "reason",    "label": "事由",       "type": "textarea", "placeholder": "私用・家族行事など（任意）" }
      ],
      "rules": [
        { "when": "days <= 3",  "route": ["sato"],             "label": "3日以内：部長承認のみ" },
        { "when": "days > 3",   "route": ["sato", "suzuki"],   "label": "4日以上：部長 → 経理" }
      ]
    },
    {
      "id": "hire",
      "title": "採用稟議",
      "icon": "fa-user-plus",
      "summary": "新規採用（正社員・契約社員・業務委託）の決定を稟議します。雇用形態に応じて承認者が変わります。",
      "fields": [
        { "key": "candidateName","label": "候補者氏名",   "type": "text",     "placeholder": "例：山本 花子" },
        { "key": "employmentType","label": "雇用形態",    "type": "select",   "options": ["正社員","契約社員","パート・アルバイト","業務委託"] },
        { "key": "position",     "label": "想定ポジション","type": "text",     "placeholder": "例：営業部 アシスタント" },
        { "key": "monthlySalary","label": "月額（円）",   "type": "number",   "placeholder": "例：280000" },
        { "key": "startDate",    "label": "入社（着任）予定日", "type": "date" },
        { "key": "evaluation",   "label": "選考所見",     "type": "textarea", "placeholder": "強み・期待役割・懸念点など" }
      ],
      "rules": [
        { "when": "employmentType == 'パート・アルバイト'", "route": ["sato"],                     "label": "パート・アルバイト：部長承認のみ" },
        { "when": "employmentType == '業務委託'",          "route": ["sato", "suzuki"],           "label": "業務委託：部長 → 経理" },
        { "when": "employmentType == '契約社員'",          "route": ["sato", "suzuki"],           "label": "契約社員：部長 → 経理" },
        { "when": "employmentType == '正社員'",            "route": ["sato", "suzuki", "yamada"], "label": "正社員：部長 → 経理 → 代表" }
      ]
    }
  ],
