---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="小説推敲ツール | Optiens"
  description="AI小説の推敲用内部ツール"
>
  <main class="review-main">
    <!-- ツールバー -->
    <div class="toolbar">
      <div class="toolbar-left">
        <span class="toolbar-title">推敲ツール</span>
        <select id="novel-select">
          <option value="">作品を選択</option>
        </select>
        <select id="chapter-select" disabled>
          <option value="">章を選択</option>
        </select>
      </div>
      <div class="toolbar-right">
        <span id="status" class="status"></span>
        <span id="save-state" class="save-state"></span>
        <button id="save-btn-top" class="action-btn primary" disabled>保存</button>
        <button id="clear-btn" class="action-btn danger" disabled>クリア</button>
      </div>
    </div>

    <!-- 空状態 -->
    <div id="empty-state" class="empty-state">
      <p>作品と章を選んでください。</p>
      <p class="empty-hint">修正メモを入力後、保存ボタンを押してください。<br>保存後にPCのClaude Codeから「推敲メモを反映して」と指示すると本文に修正が反映されます。</p>
    </div>

    <!-- エディタ -->
    <div id="editor" class="editor" style="display:none;">
      <div class="editor-header">
        <div class="col-header col-header-left">本文</div>
        <div class="col-header col-header-right">修正メモ</div>
      </div>
      <div id="editor-body" class="editor-body"></div>

      <!-- 保存済み修正メモ一覧 -->
      <div id="saved-summary" class="saved-summary" style="display:none;">
        <h3 class="saved-summary-title">保存済みの修正メモ <span id="saved-count"></span></h3>
        <div id="saved-summary-list" class="saved-summary-list"></div>
      </div>

      <!-- 下部アクションバー -->
      <div class="bottom-bar">
        <span id="bottom-state" class="save-state"></span>
        <button id="save-btn-bottom" class="action-btn primary big">保存</button>
      </div>
    </div>
  </main>
</Layout>

<script>
  const novelSelect = document.getElementById('novel-select') as HTMLSelectElement;
  const chapterSelect = document.getElementById('chapter-select') as HTMLSelectElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
  const saveBtnTop = document.getElementById('save-btn-top') as HTMLButtonElement;
  const saveBtnBottom = document.getElementById('save-btn-bottom') as HTMLButtonElement;
  const statusEl = document.getElementById('status')!;
  const saveStateEl = document.getElementById('save-state')!;
  const bottomStateEl = document.getElementById('bottom-state')!;
  const emptyState = document.getElementById('empty-state')!;
  const editor = document.getElementById('editor')!;
  const editorBody = document.getElementById('editor-body')!;
  const savedSummary = document.getElementById('saved-summary')!;
  const savedSummaryList = document.getElementById('saved-summary-list')!;
  const savedCount = document.getElementById('saved-count')!;

  let currentKey = '';
  let currentTitle = '';
  let currentLines: string[] = [];
  let savedNotes: Record<number, string> = {}; // 最後に保存されたメモ
  let isDirty = false; // 未保存の変更があるか

  interface NovelIndex { novel: string; chapters: { file: string; title: string }[] }
  let novelIndex: NovelIndex[] = [];

  // --- API ---
  async function loadNotes(key: string): Promise<Record<number, string>> {
    try {
      const res = await fetch(`/api/novel-review?key=${encodeURIComponent(key)}`);
      if (!res.ok) return {};
      const data = await res.json();
      return data.notes || {};
    } catch {
      return {};
    }
  }

  async function saveNotes(key: string, title: string, notes: Record<number, string>): Promise<boolean> {
    try {
      const res = await fetch('/api/novel-review', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key, title, notes }),
      });
      return res.ok;
    } catch {
      return false;
    }
  }

  function collectNotes(): Record<number, string> {
    const notes: Record<number, string> = {};
    editorBody.querySelectorAll('.row').forEach((row, i) => {
      const v = (row.querySelector('.row-note') as HTMLTextAreaElement).value.trim();
      if (v) notes[i] = v;
    });
    return notes;
  }

  function setDirty(dirty: boolean) {
    isDirty = dirty;
    if (dirty) {
      saveStateEl.textContent = '⚠ 未保存';
      saveStateEl.className = 'save-state dirty';
      bottomStateEl.textContent = '⚠ 未保存の変更があります';
      bottomStateEl.className = 'save-state dirty';
      saveBtnTop.classList.add('attention');
      saveBtnBottom.classList.add('attention');
    } else {
      saveStateEl.textContent = '✓ 保存済み';
      saveStateEl.className = 'save-state saved';
      bottomStateEl.textContent = '';
      saveBtnTop.classList.remove('attention');
      saveBtnBottom.classList.remove('attention');
    }
  }

  async function doSave() {
    const notes = collectNotes();
    saveStateEl.textContent = '保存中...';
    saveStateEl.className = 'save-state';
    saveBtnTop.disabled = true;
    saveBtnBottom.disabled = true;
    const ok = await saveNotes(currentKey, currentTitle, notes);
    saveBtnTop.disabled = false;
    saveBtnBottom.disabled = false;
    if (ok) {
      savedNotes = notes;
      setDirty(false);
      updateStatus(notes);
      renderRowSavedState();
      renderSavedSummary();
    } else {
      saveStateEl.textContent = '✕ 保存エラー';
      saveStateEl.className = 'save-state error';
    }
  }

  // --- Index ---
  async function loadIndex() {
    const res = await fetch('/novels/index.json');
    novelIndex = await res.json();
    novelSelect.innerHTML = '<option value="">作品を選択</option>';
    for (const n of novelIndex) {
      const o = document.createElement('option');
      o.value = n.novel;
      o.textContent = `${n.novel}（${n.chapters.length}話）`;
      novelSelect.appendChild(o);
    }
  }

  novelSelect.addEventListener('change', () => {
    if (isDirty && !confirm('未保存の変更があります。破棄して切り替えますか?')) {
      novelSelect.value = '';
      return;
    }
    const name = novelSelect.value;
    chapterSelect.innerHTML = '<option value="">章を選択</option>';
    if (!name) {
      chapterSelect.disabled = true;
      return;
    }
    const novel = novelIndex.find(n => n.novel === name);
    if (!novel) return;

    for (const ch of novel.chapters) {
      const o = document.createElement('option');
      o.value = ch.file;
      o.textContent = ch.title;
      chapterSelect.appendChild(o);
    }
    chapterSelect.disabled = false;
  });

  chapterSelect.addEventListener('change', async () => {
    if (isDirty && !confirm('未保存の変更があります。破棄して切り替えますか?')) {
      return;
    }

    const file = chapterSelect.value;
    const novel = novelSelect.value;
    if (!file || !novel) return;

    statusEl.textContent = '読み込み中...';

    const key = `${novel}/${file}`;
    const url = `/novels/${encodeURIComponent(novel)}/${encodeURIComponent(file)}`;

    const res = await fetch(url);
    if (!res.ok) {
      statusEl.textContent = '読み込みエラー';
      return;
    }
    const text = await res.text();

    // frontmatter除去
    let body = text;
    const fmMatch = text.match(/^---\n[\s\S]*?\n---\n/);
    if (fmMatch) body = text.slice(fmMatch[0].length);
    const lines = body.split('\n');

    // タイトル
    const titleMatch = text.match(/^title:\s*(.+)$/m);
    const title = titleMatch ? titleMatch[1].trim() : file.replace(/\.md$/, '');

    // サーバーからメモを取得
    const notes = await loadNotes(key);
    render(key, title, lines, notes);
  });

  // --- Render ---
  function render(key: string, title: string, lines: string[], notes: Record<number, string> = {}) {
    currentKey = key;
    currentTitle = title;
    currentLines = lines;
    savedNotes = { ...notes };
    editorBody.innerHTML = '';

    lines.forEach((line, i) => {
      const row = document.createElement('div');
      row.className = 'row';
      row.dataset.idx = String(i);
      if (notes[i]) {
        row.classList.add('has-note', 'saved-note');
      }

      const num = document.createElement('div');
      num.className = 'row-num';
      num.textContent = String(i + 1);

      const text = document.createElement('div');
      text.className = 'row-text';
      text.textContent = line;

      const note = document.createElement('textarea');
      note.className = 'row-note';
      note.placeholder = '';
      note.value = notes[i] || '';
      note.rows = 1;

      const resize = () => {
        note.style.height = 'auto';
        note.style.height = Math.max(text.offsetHeight, note.scrollHeight) + 'px';
      };

      note.addEventListener('input', () => {
        const hasContent = !!note.value.trim();
        row.classList.toggle('has-note', hasContent);
        // 保存済みの内容と差分があるかチェック
        const idx = Number(row.dataset.idx);
        const savedVal = savedNotes[idx] || '';
        if (note.value.trim() !== savedVal) {
          row.classList.add('dirty-note');
          row.classList.remove('saved-note');
        } else {
          row.classList.remove('dirty-note');
          if (hasContent) row.classList.add('saved-note');
        }
        resize();
        updateDirtyState();
      });

      note.addEventListener('focus', () => row.classList.add('focused'));
      note.addEventListener('blur', () => row.classList.remove('focused'));

      row.appendChild(num);
      row.appendChild(text);
      row.appendChild(note);
      editorBody.appendChild(row);

      requestAnimationFrame(() => {
        const h = Math.max(text.offsetHeight, note.scrollHeight);
        text.style.minHeight = h + 'px';
        note.style.height = h + 'px';
      });
    });

    emptyState.style.display = 'none';
    editor.style.display = 'block';
    clearBtn.disabled = false;
    saveBtnTop.disabled = false;
    setDirty(false);
    updateStatus(notes);
    renderSavedSummary();
  }

  function renderRowSavedState() {
    editorBody.querySelectorAll('.row').forEach((row) => {
      const idx = Number((row as HTMLElement).dataset.idx);
      const note = row.querySelector('.row-note') as HTMLTextAreaElement;
      const v = note.value.trim();
      row.classList.remove('dirty-note');
      row.classList.toggle('has-note', !!v);
      row.classList.toggle('saved-note', !!v);
    });
  }

  function renderSavedSummary() {
    const entries = Object.entries(savedNotes).sort((a, b) => Number(a[0]) - Number(b[0]));
    if (entries.length === 0) {
      savedSummary.style.display = 'none';
      return;
    }
    savedSummary.style.display = 'block';
    savedCount.textContent = `（${entries.length}件）`;
    savedSummaryList.innerHTML = '';
    for (const [idxStr, note] of entries) {
      const idx = Number(idxStr);
      const lineText = currentLines[idx] || '';
      const item = document.createElement('div');
      item.className = 'summary-item';
      item.innerHTML = `
        <div class="summary-line">
          <span class="summary-num">L${idx + 1}</span>
          <span class="summary-text"></span>
        </div>
        <div class="summary-note"></div>
      `;
      (item.querySelector('.summary-text') as HTMLElement).textContent = lineText;
      (item.querySelector('.summary-note') as HTMLElement).textContent = '→ ' + note;
      // クリックで該当行にスクロール
      item.addEventListener('click', () => {
        const targetRow = editorBody.querySelector(`.row[data-idx="${idx}"]`) as HTMLElement;
        if (targetRow) {
          targetRow.scrollIntoView({ behavior: 'smooth', block: 'center' });
          targetRow.classList.add('flash');
          setTimeout(() => targetRow.classList.remove('flash'), 1500);
        }
      });
      savedSummaryList.appendChild(item);
    }
  }

  function updateDirtyState() {
    const current = collectNotes();
    const currentJSON = JSON.stringify(current);
    const savedJSON = JSON.stringify(savedNotes);
    setDirty(currentJSON !== savedJSON);
    updateStatus(current);
  }

  function updateStatus(notes: Record<number, string>) {
    const count = Object.keys(notes).length;
    statusEl.textContent = `${currentLines.length}行 / ${count}件メモ`;
  }

  // --- 保存ボタン ---
  saveBtnTop.addEventListener('click', doSave);
  saveBtnBottom.addEventListener('click', doSave);

  // ページを離れる前の警告
  window.addEventListener('beforeunload', (e) => {
    if (isDirty) {
      e.preventDefault();
      e.returnValue = '';
    }
  });

  // --- Clear ---
  clearBtn.addEventListener('click', async () => {
    if (!confirm(`「${currentTitle}」の推敲メモを全て削除しますか?`)) return;
    const ok = await saveNotes(currentKey, currentTitle, {});
    if (ok) {
      savedNotes = {};
      editorBody.querySelectorAll('.row-note').forEach((n) => {
        (n as HTMLTextAreaElement).value = '';
      });
      editorBody.querySelectorAll('.row').forEach((r) => {
        r.classList.remove('has-note', 'saved-note', 'dirty-note');
      });
      renderSavedSummary();
      setDirty(false);
      updateStatus({});
    } else {
      alert('削除に失敗しました');
    }
  });

  loadIndex();
</script>

<style>
  .review-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 100px 12px 20px;
  }

  /* ツールバー */
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    padding: 12px 16px;
    background: #f5f5f5;
    border: 1px solid #ddd;
    border-radius: 8px;
    margin-bottom: 12px;
    position: sticky;
    top: 70px;
    z-index: 20;
  }
  .toolbar-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary, #2e574c);
    white-space: nowrap;
  }
  .toolbar-left, .toolbar-right {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  }

  .toolbar select {
    padding: 7px 10px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 0.85rem;
    max-width: 220px;
    background: #fff;
    color: #333;
  }

  .action-btn {
    padding: 7px 14px;
    border: none;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s, box-shadow 0.2s;
  }
  .action-btn:hover { opacity: 0.85; }
  .action-btn:active { transform: scale(0.97); }
  .action-btn:disabled { opacity: 0.3; cursor: not-allowed; }
  .action-btn.primary { background: var(--color-primary, #2e574c); color: #fff; }
  .action-btn.danger { background: #fee; color: #c00; }
  .action-btn.attention {
    box-shadow: 0 0 0 3px rgba(234, 67, 53, 0.3);
    animation: pulse 1.5s infinite;
  }
  .action-btn.big {
    padding: 12px 32px;
    font-size: 1rem;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(234, 67, 53, 0.3); }
    50% { box-shadow: 0 0 0 6px rgba(234, 67, 53, 0.15); }
  }

  .status {
    font-size: 0.75rem;
    color: #888;
    white-space: nowrap;
  }

  .save-state {
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .save-state.saved { color: #2e7d32; }
  .save-state.dirty { color: #c62828; }
  .save-state.error { color: #c00; }

  /* 空状態 */
  .empty-state {
    text-align: center; padding: 80px 20px; color: var(--muted, #999);
  }
  .empty-hint { font-size: 0.85rem; margin-top: 8px; line-height: 1.6; }

  /* エディタ */
  .editor { display: flex; flex-direction: column; }

  .editor-header {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 0;
    position: sticky;
    top: 130px;
    z-index: 10;
    background: var(--color-primary, #2e574c);
    border-radius: 6px 6px 0 0;
  }
  .col-header {
    padding: 8px 12px;
    font-size: 0.8rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.05em;
  }
  .col-header-left { grid-column: 2; }
  .col-header-right { grid-column: 3; border-left: 1px solid rgba(255,255,255,0.2); }

  .editor-body { display: flex; flex-direction: column; }

  /* 行 */
  .row {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 0;
    border-bottom: 1px solid #eee;
    transition: background 0.1s;
    position: relative;
  }
  .row:hover { background: rgba(94, 168, 154, 0.04); }
  .row.focused { background: rgba(94, 168, 154, 0.08); }

  /* 保存済みのメモがある行: 緑系の左ボーダー */
  .row.saved-note {
    background: rgba(46, 125, 50, 0.06);
    border-left: 4px solid #2e7d32;
  }
  .row.saved-note .row-num { color: #2e7d32; font-weight: 700; }

  /* 未保存の変更がある行: 赤系の左ボーダー */
  .row.dirty-note {
    background: rgba(234, 67, 53, 0.08);
    border-left: 4px solid #ea4335;
  }
  .row.dirty-note .row-num { color: #ea4335; font-weight: 700; }

  /* メモが空（has-noteなし）の場合は通常表示 */
  .row.has-note:not(.saved-note):not(.dirty-note) {
    background: rgba(234, 67, 53, 0.04);
  }

  .row.flash { animation: flashRow 1.5s; }
  @keyframes flashRow {
    0%, 100% { background: rgba(46, 125, 50, 0.06); }
    25% { background: rgba(255, 235, 59, 0.5); }
  }

  .row-num {
    padding: 8px 4px;
    font-size: 0.7rem;
    color: #bbb;
    text-align: center;
    user-select: none;
    border-right: 1px solid #eee;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10px;
  }

  .row-text {
    padding: 8px 12px;
    font-size: 0.9rem;
    line-height: 1.8;
    word-break: break-all;
    border-right: 1px solid #eee;
  }

  .row-note {
    padding: 8px 10px;
    font-size: 0.85rem;
    line-height: 1.6;
    border: none;
    background: transparent;
    resize: none;
    overflow: hidden;
    font-family: inherit;
    color: var(--text, #333);
  }
  .row-note:focus {
    outline: none;
    background: rgba(46, 87, 76, 0.04);
  }
  .row-note::placeholder { color: transparent; }
  .row:hover .row-note::placeholder { color: #ccc; }

  /* 保存済みサマリー */
  .saved-summary {
    margin-top: 24px;
    padding: 16px;
    background: rgba(46, 125, 50, 0.04);
    border: 1px solid rgba(46, 125, 50, 0.2);
    border-radius: 8px;
  }
  .saved-summary-title {
    margin: 0 0 12px 0;
    font-size: 0.95rem;
    color: #2e7d32;
    font-weight: 700;
  }
  .saved-summary-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .summary-item {
    padding: 8px 12px;
    background: #fff;
    border: 1px solid #e0e0e0;
    border-left: 3px solid #2e7d32;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
  }
  .summary-item:hover {
    background: rgba(46, 125, 50, 0.05);
    transform: translateX(2px);
  }
  .summary-line {
    display: flex;
    gap: 8px;
    align-items: baseline;
    margin-bottom: 4px;
  }
  .summary-num {
    font-size: 0.7rem;
    color: #2e7d32;
    font-weight: 700;
    flex-shrink: 0;
  }
  .summary-text {
    font-size: 0.85rem;
    color: #555;
    line-height: 1.5;
    word-break: break-all;
  }
  .summary-note {
    font-size: 0.85rem;
    color: #c62828;
    line-height: 1.5;
    margin-left: 32px;
    word-break: break-all;
  }

  /* 下部アクションバー */
  .bottom-bar {
    margin-top: 20px;
    padding: 16px;
    background: #f5f5f5;
    border: 1px solid #ddd;
    border-radius: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    position: sticky;
    bottom: 0;
    z-index: 15;
  }

  /* スマホ */
  @media (max-width: 768px) {
    .review-main { padding: 80px 6px 20px; }
    .toolbar { flex-direction: column; align-items: stretch; gap: 8px; padding: 10px 12px; top: 60px; }
    .toolbar-left, .toolbar-right { width: 100%; }
    .toolbar-right { justify-content: space-between; }
    .toolbar select { max-width: 100%; flex: 1; }

    .editor-header {
      grid-template-columns: 28px 1fr 1fr;
      top: 180px;
    }
    .row {
      grid-template-columns: 28px 1fr 1fr;
    }
    .row-text { font-size: 0.8rem; padding: 6px 8px; line-height: 1.7; }
    .row-note { font-size: 0.8rem; padding: 6px 8px; }
    .row-num { font-size: 0.65rem; }

    .summary-note { margin-left: 16px; }
    .bottom-bar { flex-direction: column; align-items: stretch; }
    .action-btn.big { width: 100%; }
  }
  @media (max-width: 480px) {
    .editor-header {
      grid-template-columns: 24px 1fr 1fr;
    }
    .row {
      grid-template-columns: 24px 1fr 1fr;
    }
    .row-text { font-size: 0.75rem; padding: 4px 6px; }
    .row-note { font-size: 0.75rem; padding: 4px 6px; }
  }
</style>
