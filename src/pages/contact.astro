---
import Layout from '../layouts/Layout.astro';
---

<Layout title="お問い合わせ | Optiens">
  <main class="contact-page">
    <!-- パーティクルネットワーク背景 -->
    <canvas id="contact-net" class="contact-canvas"></canvas>

    <div class="container" style="position:relative;z-index:1;">
      <h1 class="reveal">お問い合わせ</h1>
      <p class="reveal">ご質問、ご意見、ご要望など、お気軽にお問い合わせください。</p>

      <form action="/api/contact" method="POST" class="contact-form reveal">
        <div class="form-group">
          <label for="email">メールアドレス</label>
          <input type="email" id="email" name="email" required>
        </div>
        <div class="form-group">
          <label for="subject">件名</label>
          <input type="text" id="subject" name="subject" required>
        </div>
        <div class="form-group">
          <label for="message">内容</label>
          <textarea id="message" name="message" rows="8" required></textarea>
        </div>
        <button type="submit" class="btn-primary contact-submit-btn">送信</button>
      </form>
    </div>
  </main>
</Layout>

<script is:inline>
(function() {
  const canvas = document.getElementById('contact-net');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let w, h, particles, animId;
  const CONNECT_DIST = 140;
  const PARTICLE_COUNT = 80;
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function resize() {
    const rect = canvas.parentElement.getBoundingClientRect();
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    w = rect.width;
    h = rect.height;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function createParticles() {
    particles = [];
    for (let i = 0; i < PARTICLE_COUNT; i++) {
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        r: Math.random() * 1.5 + 0.5,
        color: i % 3 === 0 ? 'rgba(78,139,160,' : 'rgba(91,127,255,',
      });
    }
  }

  function draw() {
    ctx.clearRect(0, 0, w, h);

    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CONNECT_DIST) {
          const alpha = (1 - dist / CONNECT_DIST) * 0.15;
          ctx.strokeStyle = 'rgba(91,127,255,' + alpha + ')';
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.stroke();
        }
      }
    }

    for (const p of particles) {
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = p.color + '0.5)';
      ctx.fill();
    }

    if (!reducedMotion) {
      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > w) p.vx *= -1;
        if (p.y < 0 || p.y > h) p.vy *= -1;
      }
    }

    animId = requestAnimationFrame(draw);
  }

  function init() {
    resize();
    createParticles();
    draw();
  }

  window.addEventListener('resize', () => { resize(); });
  init();
})();
</script>

<style>
  .contact-page {
    position: relative;
    padding: 120px 0 60px;
    overflow: hidden;
  }
  .contact-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
  .contact-page h1 {
    text-align: center;
    margin-bottom: 20px;
    color: var(--heading);
  }
  .contact-page > .container > p {
    text-align: center;
    margin-bottom: 40px;
    color: var(--muted);
  }
  .contact-form {
    max-width: 600px;
    margin: 0 auto;
    background: var(--surface-3);
    border: 1px solid var(--border);
    padding: 32px;
    border-radius: var(--radius);
    backdrop-filter: blur(8px);
  }
  .form-group {
    margin-bottom: 20px;
  }
  .form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    font-size: .9rem;
    color: var(--heading);
  }
  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 1em;
    color: var(--text);
    transition: border-color .2s ease;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px rgba(91, 127, 255, .15);
  }
  .form-group textarea {
    resize: vertical;
  }
  .contact-submit-btn {
    width: 100%;
    padding: 15px 20px;
    font-size: 1.1em;
    margin-top: 10px;
  }
</style>
