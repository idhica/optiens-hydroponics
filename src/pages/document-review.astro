  const documentSelect = document.getElementById('document-select') as HTMLSelectElement;
  const statusEl = document.getElementById('status')!;
  const emptyState = document.getElementById('empty-state')!;
  const editor = document.getElementById('editor')!;
  const editorBody = document.getElementById('editor-body')!;
  const legend = document.getElementById('legend')!;

  // セレクタ初期化
  for (const doc of SAMPLE_DOCUMENTS) {
    const o = document.createElement('option');
    o.value = doc.id;
    o.textContent = doc.title;
    documentSelect.appendChild(o);
  }

  documentSelect.addEventListener('change', () => {
    const id = documentSelect.value;
    if (!id) {
      emptyState.style.display = 'block';
      editor.style.display = 'none';
      legend.style.display = 'none';
      statusEl.textContent = '';
      return;
    }
    const doc = SAMPLE_DOCUMENTS.find(d => d.id === id);
    if (!doc) return;
    render(doc);
  });

  function render(doc: SampleDoc) {
    editorBody.innerHTML = '';
    const lines = doc.content.split('\n');

    // 行番号 → ノート配列のマップ作成
    const notesByLine = new Map<number, Note[]>();
    for (const n of doc.notes) {
      if (!notesByLine.has(n.line)) notesByLine.set(n.line, []);
      notesByLine.get(n.line)!.push(n);
    }

    lines.forEach((line, i) => {
      const lineNo = i + 1;
      const row = document.createElement('div');
      row.className = 'row';
      const rowNotes = notesByLine.get(lineNo) || [];
      if (rowNotes.length > 0) {
        row.classList.add('has-note');
        // 最も高い重要度を行のフラグに
        const sevRank: Record<Severity, number> = { high: 3, medium: 2, low: 1 };
        const top = rowNotes.reduce((a, b) => sevRank[a.severity] >= sevRank[b.severity] ? a : b);
        row.classList.add(`sev-${top.severity}`);
      }

      const num = document.createElement('div');
      num.className = 'row-num';
      num.textContent = String(lineNo);

      const text = document.createElement('div');
      text.className = 'row-text';
      text.textContent = line || ' '; // 空行も高さ確保

      const noteCol = document.createElement('div');
      noteCol.className = 'row-note';

      if (rowNotes.length === 0) {
        noteCol.innerHTML = '';
      } else {
        for (const n of rowNotes) {
          const card = document.createElement('div');
          card.className = `note-card note-${n.severity}`;

          const head = document.createElement('div');
          head.className = 'note-head';
          const badge = document.createElement('span');
          badge.className = `note-badge badge-${n.severity}`;
          badge.textContent = n.severity === 'high' ? '重要' : n.severity === 'medium' ? '中' : '軽微';
          const title = document.createElement('span');
          title.className = 'note-title';
          title.textContent = n.title;
          head.appendChild(badge);
          head.appendChild(title);

          const body = document.createElement('div');
          body.className = 'note-body';
          body.textContent = n.comment;

          card.appendChild(head);
          card.appendChild(body);

          // タップで詳細展開
          card.addEventListener('click', (e) => {
            e.stopPropagation();
            card.classList.toggle('expanded');
          });

          noteCol.appendChild(card);
        }
      }

      row.appendChild(num);
      row.appendChild(text);
      row.appendChild(noteCol);
      editorBody.appendChild(row);
    });

    emptyState.style.display = 'none';
    editor.style.display = 'block';
    legend.style.display = 'flex';

    const high = doc.notes.filter(n => n.severity === 'high').length;
    const med = doc.notes.filter(n => n.severity === 'medium').length;
    const low = doc.notes.filter(n => n.severity === 'low').length;
    statusEl.textContent = `${doc.notes.length}件の指摘（重要${high} / 中${med} / 軽微${low}）`;
  }
</script>

