---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="書類添削ツール | Optiens"
  description="経営者向け書類添削ツール（デモ）。AIエージェントによる文書レビュー支援のサンプル表示。"
  noindex={true}
>
  <main class="review-main">
    <!-- ツールバー -->
    <div class="toolbar">
      <div class="toolbar-left">
        <span class="toolbar-title">書類添削ツール</span>
        <select id="document-select" aria-label="書類を選択">
          <option value="">書類を選択</option>
        </select>
      </div>
      <div class="toolbar-right">
        <span id="status" class="status"></span>
      </div>
    </div>

    <!-- 重要度凡例 -->
    <div class="legend" id="legend" style="display:none;">
      <span class="legend-item legend-high"><span class="dot"></span>重要</span>
      <span class="legend-item legend-medium"><span class="dot"></span>中</span>
      <span class="legend-item legend-low"><span class="dot"></span>軽微</span>
      <span class="legend-hint">行をタップでメモ詳細を開閉</span>
    </div>

    <!-- 空状態 -->
    <div id="empty-state" class="empty-state">
      <p>書類を選んでください。</p>
      <p class="empty-hint">AIエージェントが文書を読み、重要度付きで指摘メモを表示します。</p>
    </div>

    <!-- エディタ -->
    <div id="editor" class="editor" style="display:none;">
      <div class="editor-header">
        <div class="col-header col-header-left">本文</div>
        <div class="col-header col-header-right">AI添削メモ</div>
      </div>
      <div id="editor-body" class="editor-body"></div>
    </div>
  </main>
</Layout>

<script>
  // 重要度型
  type Severity = 'high' | 'medium' | 'low';
  interface Note {
    line: number;       // 1始まりの行番号（本文セクション内）
    severity: Severity;
    title: string;      // 指摘タイトル
    comment: string;    // 提案本文
  }
  interface SampleDoc {
    id: string;
    title: string;
    content: string;    // 書類本文
    notes: Note[];
  }

  // ============================================================
  // サンプル書類7件（フィクスチャ）
  // sample-documents/ 配下のMarkdownを書類本文＋AI添削メモに分解して埋め込み
  // ============================================================
  const SAMPLE_DOCUMENTS: SampleDoc[] = [
