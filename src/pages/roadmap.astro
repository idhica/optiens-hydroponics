---
import Layout from '../layouts/Layout.astro';

import bgUrl from '~/assets/ai-nature-city.webp?url';
---

<Layout title="ロードマップ | Optiens">
  <main>

    <!-- ===== Hero ===== -->
    <section class="hero-section" style={`--hero-bg: url(${bgUrl});`}>
      <div class="container text-center">
        <h1>ロードマップ</h1>
        <p class="hero-sub">閉鎖循環水耕モジュール＋運用SaaSの段階的な実証・商業化計画</p>
      </div>
    </section>

    <!-- ===== 概要 ===== -->
    <section class="section-intro container prose">
      <h2>実行計画の概要</h2>
      <p>
        Optiensは医療機関・防災拠点・孤立環境（離島・船舶・地下施設）を対象に、
        低電力・自律運転の閉鎖循環水耕モジュールと運用SaaS（遠隔監視・最適化・技術サポート）を段階的に展開します。
        各フェーズで再現性・衛生・稼働率を定量的に立証しながら、有償SaaS契約を積み上げていく計画です。
      </p>
    </section>

    <!-- ===== タイムライン ===== -->
    <section class="section-timeline container">
      <ol class="timeline" aria-label="実行ロードマップ">

        <!-- Phase 0 ★現在フェーズ -->
        <li class="phase phase--current" id="phase0">
          <div class="phase-header">
            <span class="phase-badge phase-badge--current">Phase 0</span>
            <span class="phase-status">進行中</span>
          </div>
          <h2 class="phase-title">法人設立・基盤構築</h2>
          <p class="phase-period">～2026年6月</p>
          <ul class="phase-items">
            <li>一般社団法人 Optiens 設立・登記</li>
            <li>主要要件確定（低電力/衛生/冗長/遠隔運用）／BOM確定（極力COTS採用）</li>
            <li>小規模ラック＋電力計・温湿度・EC/pHの計測系を準備</li>
            <li>連携候補（大学/病院/自治体/防災）とPoC覚書の素案作成</li>
            <li>補助金申請準備（農水省スマート農業補助金等）</li>
          </ul>
        </li>

        <!-- Phase 1 -->
        <li class="phase phase--upcoming" id="phase1">
          <div class="phase-header">
            <span class="phase-badge">Phase 1</span>
            <span class="phase-status">次フェーズ</span>
          </div>
          <h2 class="phase-title">プロトタイプ・小規模実証</h2>
          <p class="phase-period">2026年7月～2027年3月</p>
          <ul class="phase-items">
            <li>20–40L級の閉鎖循環ミニループを製作</li>
            <li>LED・ポンプ・制御の電力ベンチ</li>
            <li>SaaSに遠隔監視・しきい値アラート実装</li>
            <li>デモンストレーション農場の設置・運用開始</li>
          </ul>
          <p class="phase-goal"><strong>目標：</strong>平均消費電力 &lt;80W、循環率 &gt;95%</p>
        </li>

        <!-- Phase 2 -->
        <li class="phase phase--future" id="phase2">
          <div class="phase-header">
            <span class="phase-badge">Phase 2</span>
            <span class="phase-status">計画</span>
          </div>
          <h2 class="phase-title">短期実証・システムv1.0</h2>
          <p class="phase-period">2027年4月～2028年3月</p>
          <ul class="phase-items">
            <li>パートナー設備内で4–6週間の連続運転</li>
            <li>SOP（洗浄・補給・障害時手順）と安全チェックリスト整備</li>
            <li>LCAベースライン取得</li>
            <li>運用SaaSの有償契約先3社の獲得（遠隔監視・最適化・技術サポートを含む）</li>
          </ul>
          <p class="phase-goal"><strong>目標：</strong>稼働率 &gt;98%、葉物エネルギー効率 8–12 kWh/kg</p>
        </li>

        <!-- Phase 3 -->
        <li class="phase phase--future" id="phase3">
          <div class="phase-header">
            <span class="phase-badge">Phase 3</span>
            <span class="phase-status">計画</span>
          </div>
          <h2 class="phase-title">有償パイロット・商業化</h2>
          <p class="phase-period">2028年4月～2029年3月</p>
          <ul class="phase-items">
            <li>「シングルベイMVP（~0.5㎡級）」を設置・遠隔運用</li>
            <li>最低1拠点で有償評価（病院/防災拠点など）</li>
            <li>SLA試案（稼働率、MTTR）と月額SaaSの算定式を提示</li>
            <li>運用SaaS契約先10社以上へ拡大</li>
          </ul>
          <p class="phase-goal"><strong>目標：</strong>エネルギー効率 6–10 kWh/kg、MTTR &lt;24h、衛生指標クリア</p>
        </li>

      </ol>
    </section>

    <!-- ===== 主要指標 ===== -->
    <section class="section-kpis container prose">
      <h2>主要指標と目標値</h2>
      <ul class="ticks">
        <li><strong>エネルギー効率：</strong>葉物 6–10 kWh/kg（MVP時）／エネルギーコスト比率 20%未満</li>
        <li><strong>稼働率/SLA：</strong>稼働率 &gt;98%、MTTR &lt;24h</li>
        <li><strong>水循環率：</strong>&gt;95%、廃液管理SOPを文書化</li>
        <li><strong>衛生・洗浄性：</strong>ATP/微生物指標のしきい値合格、洗浄時間の標準化</li>
        <li><strong>運用SaaS：</strong>遠隔監視・アラート・運転最適化・技術サポートを一体提供、貢献利益率 80%以上</li>
        <li><strong>事業面：</strong>有償パイロット≧1拠点、運用SaaS有償契約先 1年目3社・2年目10社、LOI/覚書≧2件</li>
      </ul>
    </section>

    <!-- ===== CTA ===== -->
    <section class="section-cta container">
      <h2>詳細資料・お問い合わせ</h2>
      <p>投資・協業・実証フィールドのご提供に関するご相談は下記よりご連絡ください。</p>
      <div class="cta-btns">
        <a
          href="/一般社団法人_水耕栽培自動化_事業計画書.pdf"
          class="btn-primary"
          download="一般社団法人_水耕栽培自動化_事業計画書.pdf"
          target="_blank"
          rel="noopener"
        >事業計画書をダウンロード</a>
        <a href="/contact" class="btn-primary">お問い合わせ</a>
        <a href="/investors" class="btn-secondary">投資家情報を見る</a>
      </div>
    </section>

    <!-- ===== 注記 ===== -->
    <section class="section-notes container">
      <p class="note-text">※ 本ページのスケジュール・数値目標・ロードマップは将来予測を含み、変更される可能性があります。</p>
    </section>

  </main>
</Layout>

<style>
/* ========== Layout ========== */
:root {
  --maxw: 860px;
  --header-offset-mobile: 84px;
  --header-offset-desktop: 104px;
}

main {
  padding-top: calc(env(safe-area-inset-top, 0px) + var(--header-offset-desktop));
}
@media (max-width: 768px) {
  main { padding-top: calc(env(safe-area-inset-top, 0px) + var(--header-offset-mobile)); }
}

section { padding: clamp(48px, 8vw, 80px) 0; }

.container { width: min(var(--maxw), 100% - 2rem); margin-inline: auto; }

/* ========== Hero sub ========== */
.hero-sub {
  font-size: clamp(14px, 1.8vw, 17px);
  margin-top: .75rem;
  opacity: .9;
  line-height: 1.7;
}

/* ========== Intro ========== */
.section-intro { padding-bottom: 0; }

/* ========== Timeline ========== */
.section-timeline { padding-top: clamp(32px, 5vw, 56px); }

.timeline {
  list-style: none;
  padding: 0;
  margin: 0;
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* 縦線 */
.timeline::before {
  content: '';
  position: absolute;
  left: 28px;
  top: 0;
  bottom: 0;
  width: 3px;
  background: linear-gradient(to bottom, var(--brand), var(--brand-2) 60%, #ccc);
  border-radius: 2px;
  z-index: 0;
}

/* ========== Phase カード ========== */
.phase {
  position: relative;
  padding: 28px 28px 28px 76px;
  border-radius: 12px;
  margin-bottom: 24px;
  transition: box-shadow .2s ease, transform .2s ease;
}
.phase:last-child { margin-bottom: 0; }

/* 縦線上の丸 */
.phase::before {
  content: '';
  position: absolute;
  left: 20px;
  top: 32px;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 3px solid var(--brand);
  background: var(--surface);
  z-index: 1;
}

/* ---- 現在フェーズ ---- */
.phase--current {
  background: color-mix(in srgb, var(--brand) 8%, transparent);
  border: 2px solid var(--brand);
  box-shadow: 0 6px 20px rgba(46,87,76,.14);
}
.phase--current::before {
  background: var(--brand);
  border-color: var(--brand);
  box-shadow: 0 0 0 4px color-mix(in srgb, var(--brand) 20%, transparent);
}
.phase--current:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 28px rgba(46,87,76,.18);
}

/* ---- 次フェーズ ---- */
.phase--upcoming {
  background: color-mix(in srgb, var(--brand-2) 6%, transparent);
  border: 1.5px solid color-mix(in srgb, var(--brand-2) 40%, transparent);
}
.phase--upcoming::before {
  border-color: var(--brand-2);
}

/* ---- 将来フェーズ ---- */
.phase--future {
  background: var(--surface-2, #f7f7f7);
  border: 1.5px solid #e0e0e0;
}
.phase--future::before {
  border-color: #bbb;
}

/* ========== Phase ヘッダー ========== */
.phase-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.phase-badge {
  display: inline-block;
  padding: 3px 12px;
  border-radius: 9999px;
  font-size: .82rem;
  font-weight: 700;
  background: var(--brand);
  color: #fff;
  letter-spacing: .04em;
}
.phase-badge--current {
  background: var(--brand);
  box-shadow: 0 2px 8px rgba(46,87,76,.3);
}
.phase--upcoming .phase-badge { background: var(--brand-2); }
.phase--future .phase-badge {
  background: #999;
}

.phase-status {
  font-size: .8rem;
  color: var(--muted);
  font-weight: 500;
}
.phase--current .phase-status {
  color: var(--brand);
  font-weight: 700;
}

/* ========== Phase コンテンツ ========== */
.phase-title {
  font-size: clamp(18px, 2.4vw, 22px);
  font-weight: 800;
  color: var(--heading);
  margin: 0 0 4px;
  line-height: 1.3;
}

.phase-period {
  font-size: .88rem;
  color: var(--muted);
  margin: 0 0 16px;
  font-weight: 500;
}
.phase--current .phase-period { color: var(--brand); font-weight: 700; }

.phase-items {
  list-style: none;
  padding: 0;
  margin: 0 0 12px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.phase-items li {
  position: relative;
  padding-left: 1.4em;
  font-size: .95rem;
  line-height: 1.7;
  color: var(--text);
}
.phase-items li::before {
  content: '›';
  position: absolute;
  left: 0;
  top: 0;
  color: var(--brand-2);
  font-weight: 700;
  font-size: 1.1em;
  line-height: 1.5;
}
.phase--future .phase-items li { color: var(--muted); }

.phase-goal {
  font-size: .9rem;
  color: var(--text);
  background: color-mix(in srgb, var(--brand) 6%, transparent);
  border-left: 3px solid var(--brand);
  padding: 8px 12px;
  border-radius: 0 6px 6px 0;
  margin: 0;
  line-height: 1.6;
}
.phase--future .phase-goal {
  background: rgba(0,0,0,.03);
  border-left-color: #bbb;
  color: var(--muted);
}

/* ========== KPIs ========== */
.section-kpis {
  background: var(--surface-2, #f7f7f7);
  border-radius: 16px;
  padding: clamp(32px, 5vw, 56px) clamp(20px, 4vw, 40px);
}
.ticks { list-style: none; padding: 0; margin: 0; }
.ticks li {
  position: relative;
  padding-left: 1.6rem;
  margin: .6rem 0;
  line-height: 1.7;
  font-size: .97rem;
  color: var(--text);
}
.ticks li::before {
  content: '✔';
  position: absolute;
  left: 0;
  top: 0;
  line-height: 1.4;
  color: var(--brand);
  font-size: .9em;
}

/* ========== CTA ========== */
.section-cta {
  text-align: center;
}
.section-cta h2 {
  font-size: clamp(20px, 2.8vw, 26px);
  color: var(--heading);
  margin: 0 0 .75rem;
}
.section-cta p {
  color: var(--muted);
  margin: 0 0 1.5rem;
  font-size: .97rem;
}
.cta-btns {
  display: flex;
  gap: .9rem;
  flex-wrap: wrap;
  justify-content: center;
}
.btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: .75rem 1.25rem;
  min-height: 44px;
  font-size: clamp(14px, 1.6vw, 16px);
  font-weight: 700;
  cursor: pointer;
  color: var(--brand);
  background: transparent;
  border: 2px solid var(--brand);
  border-radius: 9999px;
  transition: background .2s ease, color .2s ease, transform .2s ease;
  text-decoration: none;
}
.btn-secondary:hover {
  background: color-mix(in srgb, var(--brand) 8%, transparent);
  transform: translateY(-1px);
}

/* ========== Notes ========== */
.section-notes { padding-top: 0; }
.note-text {
  font-size: .88rem;
  color: var(--muted);
  text-align: center;
}

/* ========== Responsive ========== */
@media (max-width: 640px) {
  .timeline::before { left: 20px; }
  .phase { padding: 20px 16px 20px 56px; }
  .phase::before { left: 12px; top: 24px; width: 16px; height: 16px; }
  .phase-title { font-size: clamp(17px, 4.5vw, 20px); }
  .cta-btns { flex-direction: column; align-items: stretch; }
  .cta-btns .btn-primary,
  .cta-btns .btn-secondary { text-align: center; }
}
</style>
