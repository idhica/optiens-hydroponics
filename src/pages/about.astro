---
import Layout from '../layouts/Layout.astro';
import poster from '../assets/about-poster.jpg?url';
import founderPhoto from '../assets/founder.jpg?url';
const fbLink = 'https://www.facebook.com/profile.php?id=61564033651814';
---

<Layout title="会社情報 | Optiens">
  <main>
    <!-- ===== Hero（動画） ===== -->
    <section
      class="about-hero-section"
      style={`--hero-poster: url(${poster});`}
    >
      <video
        autoplay muted loop playsinline preload="metadata"
        poster={poster} aria-hidden="true"
      >
        <source src="/videos/about_compressed.webm" type="video/webm" />
        <source src="/videos/about_compressed.mp4" type="video/mp4" />
        お使いのブラウザは動画タグをサポートしていません。
      </video>

      <div class="hero-content">
        <div class="container text-center">
          <h1>ABOUT</h1>
          <p>持続可能な循環社会へ</p>
        </div>
      </div>
    </section>

    <!-- ===== Content ===== -->
    <section class="about-content-section">
      <div class="container">

        <!-- ミニ・ヒーロー（About専用の軽量版） -->
        <section class="hero-container hero-container--inline">
          <div class="hero-block">
            <div class="hero-title">
              <p class="eyebrow">GRAND VISION</p>
              <h2 class="hero-lead hero-lead--xl">
                DESIGNING A FUTURE WHERE PEOPLE<br/>
                AND THE PLANET THRIVE TOGETHER.
              </h2>
            </div>
            <p class="hero-lead hero-lead--sm">
              人と地球が共に豊かになる未来をデザインする。
            </p>
          </div>
        </section>

        <!-- 1) Optiensの由来 -->
        <section class="about-origin">
          <h2>次の世代へ繋ぐために</h2>
            <p>Optiens（オプティエンス） は <strong>Optimization（最適化）</strong> と <strong>Ensō（円相）</strong>を重ねた造語です。</p>
            <p>既成概念を見直し、社会や暮らしの仕組みを最適化していきます。</p>
        </section>

        <!-- 2) 代表メッセージ -->
        <section class="founder-letter">
          <div class="founder-layout">
            <!-- <a class="founder-photo-link" href={fbLink} target="_blank" rel="noopener">
              <img
                src={founderPhoto}
                alt="代表者の写真"
                loading="lazy"
                decoding="async"
                width="640"
                height="640"
              />
            </a> -->

            <!-- 新： -->
            <div class="founder-photo">
              <img
                src={founderPhoto}
                alt="代表者の写真"
                loading="lazy"
                decoding="async"
                width="640"
                height="640"
              />
              <a class="founder-badge fb" href={fbLink} target="_blank" rel="noopener" aria-label="Facebook">
                <!-- Facebook “f” マーク（SVG）-->
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="currentColor"
                    d="M22 12a10 10 0 1 0-11.5 9.9v-7H8.6v-3h1.9V9.6c0-1.9 1.2-3.2 3.1-3.2.9 0 1.8.1 1.8.1v2h-1.1c-1.0 0-1.3.6-1.3 1.2V12h2.4l-.4 3h-2v7A10 10 0 0 0 22 12z"/>
                </svg>
              </a>
            </div>

            <div class="founder-body">
              <h2>代表メッセージ</h2>
              <p class="lede">
                競争から協調へ、所有から共有へ、分離から統合へ。<br/>
                ──時代は大きな転換点にあります。
              </p>
              <p>
                産業革命以降の数世紀、社会は大量生産・大量消費と物質的な成長を軸に発展してきました。<br/>
                いま私たちは、テクノロジーや効率だけでなくウェルビーイングやレジリエンス、自然との共存を重視する価値観へと移行しつつあります。<br/>
                形があるモノよりも、知識・創造性・コミュニケーションといった形がないモノが社会を動かし、小さなコミュニティや個人が主体となる時代が始まりました。
              </p>
              <p>
                一方で、前時代的な問題が顕在化していると思える状況が見えてきております。<br/>
                気温上昇や水ストレス、物流・エネルギーの不確実性の高まり、他国による土地・水源地の買い占め、メガソーラーの設置、水道民営化、カントリーリスクなど。<br/>
                これらのネガティブな面が既存の食料供給の基盤をリスクにさらしています。<br/>
                Optiensは、こうした変化を先取りし、農業を“再設計”するために生まれました。
              </p>
              <p>
                私たちは、安定供給の再現性が高い閉鎖循環型の水耕モジュールを、低電力設計 × 自律制御 × 運用SaaSで開発しています。<br/>
                設備を売って終わるのではなく、運用データで学習し続ける”生きたインフラ”を提供します。<br/>
                医療・防災・孤立環境から始め、10年先、100年先も安心して食べられる環境の構築を目指します。
              </p>
              <p>
                小さく確実に動くMVPから始め、ロードマップに沿って段階的にスケールさせます。<br/>
                多くの方にこの課題へ関心を寄せていただき、力を合わせて前進できれば幸いです。
              </p>
            </div>

          </div>
        </section>

        <aside class="founder-notes">
          <p class="supplement">
            <span class="label">ウェルビーイング：</span>
            身体・心・社会（つながりや安心）・環境まで含めた、総合的に良い状態。ウェルネス（個人の健康習慣）よりも、組織や地域・環境まで視野が広い概念。
          </p>
          <p class="supplement">
            <span class="label">レジリエンス：</span>
            困難やストレスに直面しても、立ち直り、学び、適応していく力。
          </p>
          <p class="supplement">
            <span class="label">MVP：</span>
            Minimum Viable Product（最小実用製品）。最小限の機能で価値を届けつつ、実地のデータを得るための初期版。
          </p>
        </aside>


      </div>
    </section>
  </main>
</Layout>

<style>
/* =========================================================
   About 上部の動画ヒーロー（既存の見た目を維持）
   ========================================================= */
.about-hero-section{
  position: relative;
  overflow: hidden;
  min-height: clamp(480px, 66svh, 80svh);
  display: flex; align-items: center; justify-content: center;
  background-image: var(--hero-poster),
                    var(--brand-gradient, linear-gradient(135deg,#2e574c,#5ea89a));
  background-size: cover; background-position: center; background-repeat: no-repeat;
  color: var(--on-hero, #fff);
}
.about-hero-section::before{ content:''; position:absolute; inset:0; background: rgba(0,0,0,.45); z-index:1; }
.about-hero-section video{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:0; pointer-events:none; }
.about-hero-section .hero-content{ position:relative; z-index:2; padding: clamp(56px, 8vw, 112px) 20px; width:100%; text-align:center; }
.about-hero-section .hero-content h1{ font-size: clamp(28px, 6vw, 56px); line-height:1.15; margin:0 0 12px; color:#fff; }
.about-hero-section .hero-content p{ font-size: clamp(14px, 2vw, 18px); line-height:1.7; max-width: 900px; margin:0 auto; color:#fff; }

/* =========================================================
   About 本文
   ========================================================= */
.about-content-section{ padding: 64px 20px; background: var(--surface, #fff); line-height:1.8; }
.about-content-section .container{ width: min(1000px, 100% - 2rem); margin-inline: auto; }

/* =========================================================
   ミニ・ヒーロー（カード）
   “列（--col-w）”を全要素で共有して左起点を完全一致
   ========================================================= */
.about-content-section .hero-container--inline{
  position: relative;
  container-type: inline-size;
  --pad-x: clamp(24px, 4vw, 40px);
  padding: var(--pad-x);
  margin-bottom: 48px;
  background: var(--surface, #fff);
  border: 1px solid color-mix(in srgb, var(--brand-2, #5ea89a) 22%, transparent);
  border-radius: 10px;
  box-shadow: 0 8px 30px rgba(0,0,0,.06);
  color: #111; text-shadow: none;
  --inner-w: calc(100% - (var(--pad-x) * 2));
  --col-w: min(56rem, var(--inner-w));
}
.about-content-section .hero-container--inline::before{ display:none; }
.about-content-section .hero-container--inline .hero-block{ display:grid; gap:.75rem; box-sizing:border-box; }
.about-content-section .hero-container--inline .hero-title{ width: var(--col-w); max-width: 100%; margin-inline: auto; }
.about-content-section .hero-container--inline .eyebrow{
  margin:0 0 .75rem; text-align:left; font-size: clamp(11px, 1vw, 13px);
  letter-spacing:.18em; text-transform:uppercase; color:#76b2a8; opacity:.95;
}
.about-content-section .hero-container--inline .hero-lead{ margin:0 0 1em; line-height:1.2; letter-spacing:.02em; }
.about-content-section .hero-container--inline .hero-lead--xl{ text-align:left; font-size: clamp(28px, 3.6vw, 44px); text-wrap: balance; }

/* 日本語サブコピー：PC は右寄せ、SP は1行フィット */
.about-content-section .hero-container--inline .hero-lead--sm{
  width: var(--col-w); max-width: 100%; margin-inline: auto;
  text-align: right; font-size: clamp(14px, 1.8vw, 18px);
  color:#666; font-weight:600;
}
@media (max-width: 640px){
  .about-content-section .hero-container--inline{ --col-w: calc(100% - (var(--pad-x) * 2)); }
  .about-content-section .hero-container--inline .hero-lead--xl{ font-size: clamp(18px, 5.2vw, 26px); }
  .about-content-section .hero-container--inline .hero-lead--sm{
    width: var(--col-w); margin-inline:auto;
    text-align: left;
    white-space: nowrap;
    font-size: min(16px, calc((100cqw - (var(--pad-x) * 2) - 36px) / 22));
    line-height: 1.35; letter-spacing: 0;
  }
}
@supports not (width: 1cqw){
  @media (max-width: 640px){
    .about-content-section .hero-container--inline .hero-lead--sm{
      font-size: clamp(12px, 3.6vw, 16px);
      white-space: nowrap;
    }
  }
}

/* =========================================================
   代表メッセージ（写真は見出し＋リードの段にだけ表示）
   本文はその下でカード全幅を使用
   ========================================================= */
.founder-letter{
  --founder-gap: clamp(36px, 6vw, 80px);  /* ← ここで上の余白量を調整できます */
  max-width: 1000px;
  margin: var(--founder-gap) auto 0;       /* ← 上にスキマを作成 */
  padding: 3rem 1.5rem;
  background: var(--surface-2, #f9f9f9);
  border-radius: 12px;
  box-shadow: 0 8px 30px rgba(0,0,0,.06);
}

/* 上段だけ 2 カラム（写真 + タイトル/リード）、下段以降は全幅 */
.founder-layout{
  --photo-size: 110px;                /* デスクトップの写真サイズ */
  --badge-size: 32px;                 /* FBロゴボタンのサイズ */
  display: grid;
  grid-template-columns: var(--photo-size) 1fr;
  column-gap: 24px;
  align-items: start;
}

/* 写真（上段2行を占有） */
.founder-photo{
  grid-column: 1; grid-row: 1 / 3;
  width: var(--photo-size); max-width: var(--photo-size);
  position: relative;
  border-radius:12px; overflow:hidden; line-height:0;
  box-shadow: 0 6px 18px rgba(0,0,0,.08);
}
.founder-photo img{
  width: 100%; height: 100%;
  aspect-ratio: 1 / 1; object-fit: cover; display:block;
}

/* Facebookロゴボタン（写真の近くに表示） */
.founder-badge{
  position: absolute;
  left: 8px; bottom: -10px;
  width: var(--badge-size); height: var(--badge-size);
  display: grid; place-items: center;
  border-radius: 9999px;
  background: #1877F2; color: #fff;
  box-shadow: 0 6px 14px rgba(24,119,242,.35);
  text-decoration: none;
  transition: transform .15s ease, box-shadow .15s ease, filter .15s ease;
}
.founder-badge svg{ width: 60%; height: 60%; display:block; }
.founder-badge:hover{ transform: translateY(-1px); filter: brightness(1.05); }
.founder-badge:focus-visible{
  outline: 0;
  box-shadow: 0 0 0 4px color-mix(in srgb, #1877F2 35%, white);
}

/* 見出しとリードは写真の右隣（上段2行） */
.founder-body{ display: contents; }
.founder-body h2{
  grid-column: 2; grid-row: 1;
  font-size: clamp(22px, 3vw, 28px);
  font-weight: 800; margin: 0 0 0.35rem; color:#111; text-align: left;
}
.founder-body .lede{
  grid-column: 2; grid-row: 2;
  font-size: clamp(16px, 2.2vw, 20px);
  font-weight: 700; color: var(--brand, #2e574c);
  margin: 0 0 1rem; text-align: left;
}

/* 以降の本文は新しい行で “全幅（1~2列）” を占有 */
.founder-body p:not(.lede),
.founder-body ul, .founder-body ol{
  grid-column: 1 / -1;
  margin: 0 0 1rem;
  color: var(--text, #1a1a1a); line-height: 1.8;
}

/* ===== 代表メッセージ下の補足ノート（カード外・小さく） ===== */
.founder-notes{
  width: min(1000px, 100% - 2rem);
  margin: 10px auto 0;         /* カードの直下に密着しすぎない程度の余白 */
  padding: 8px 2px;
  color: var(--muted, #666);
  font-size: clamp(12px, 1.2vw, 13.5px);
  line-height: 1.7;
}
.founder-notes .supplement{
  margin: 6px 0;
}
.founder-notes .label{
  font-weight: 600;            /* <strong>ではなく程よい太さで可読性を確保 */
  color: color-mix(in srgb, var(--muted, #666) 70%, #000);
  margin-right: .25em;
  white-space: nowrap;
}

/* PCでも本文と混ざらないよう“外側”の見え方を軽く差別化（任意） */
.founder-notes{
  border-left: 3px solid color-mix(in srgb, var(--brand, #2e574c) 35%, #999);
  padding-left: 10px;
  opacity: .95;
}

/* モバイル微調整 */
@media (max-width: 640px){
  .founder-notes{ margin-top: 8px; padding-left: 8px; }
  .founder-notes .label{ font-weight: 600; }
}

/* モバイル：写真/バッジサイズ縮小。段組は維持、本文は全幅 */
@media (max-width: 800px){
  .founder-layout{ --photo-size: 88px; --badge-size: 28px; column-gap: 16px; }
  .founder-badge{ bottom: -8px; left: 6px; }
}
@media (max-width: 520px){
  .founder-layout{ --photo-size: 78px; --badge-size: 24px; column-gap: 14px; }
  .founder-badge{ bottom: -6px; left: 6px; }
}

/* a11y: 動画を無効化 */
@media (prefers-reduced-motion: reduce){
  .about-hero-section video{ display:none; }
}
</style>
