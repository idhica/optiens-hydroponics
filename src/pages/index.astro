---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Optiens | AIで事業をつくる会社"
  description="エンタープライズシステム10年超の経験を、小さな事業に最適化。無料AI診断から導入・保守まで、AIエージェントによる業務自動化を伴走支援します。"
>
  <main>
    <!-- ===== ヒーロー ===== -->
    <section class="hero">
      <canvas id="hero-net" class="hero-canvas"></canvas>
      <div class="hero-content">
        <p class="hero-eyebrow">NEXT STEP WITH AI</p>
        <h1 class="hero-title">
          MAKE AI NATIVE<br/>
          TO YOUR BUSINESS.
        </h1>
        <p class="hero-sub">AIを事業の中心に。</p>
        <a href="/free-diagnosis" class="btn-primary hero-cta">無料AI診断を受ける</a>
      </div>
    </section>

    <script is:inline>
    (function() {
      const canvas = document.getElementById('hero-net');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      let w, h, particles, animId;
      const CONNECT_DIST = 140;
      const PARTICLE_COUNT = 80;
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function resize() {
        const rect = canvas.parentElement.getBoundingClientRect();
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        w = rect.width;
        h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function createParticles() {
        particles = [];
        for (let i = 0; i < PARTICLE_COUNT; i++) {
          particles.push({
            x: Math.random() * w,
            y: Math.random() * h,
            vx: (Math.random() - 0.5) * 0.4,
            vy: (Math.random() - 0.5) * 0.4,
            r: Math.random() * 1.5 + 0.5,
            // Alternate lapis blue and titanium blue
            color: i % 3 === 0 ? 'rgba(78,139,160,' : 'rgba(91,127,255,',
          });
        }
      }

      function draw() {
        ctx.clearRect(0, 0, w, h);

        // Draw connections
        for (let i = 0; i < particles.length; i++) {
          for (let j = i + 1; j < particles.length; j++) {
            const dx = particles[i].x - particles[j].x;
            const dy = particles[i].y - particles[j].y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < CONNECT_DIST) {
              const alpha = (1 - dist / CONNECT_DIST) * 0.15;
              ctx.strokeStyle = 'rgba(91,127,255,' + alpha + ')';
              ctx.lineWidth = 0.5;
              ctx.beginPath();
              ctx.moveTo(particles[i].x, particles[i].y);
              ctx.lineTo(particles[j].x, particles[j].y);
              ctx.stroke();
            }
          }
        }

        // Draw particles
        for (const p of particles) {
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fillStyle = p.color + '0.5)';
          ctx.fill();
        }

        // Move particles
        if (!reducedMotion) {
          for (const p of particles) {
            p.x += p.vx;
            p.y += p.vy;
            if (p.x < 0 || p.x > w) p.vx *= -1;
            if (p.y < 0 || p.y > h) p.vy *= -1;
          }
        }

        animId = requestAnimationFrame(draw);
      }

      function init() {
        resize();
        createParticles();
        draw();
      }

      window.addEventListener('resize', () => {
        resize();
      });

      init();
    })();
    </script>

    <!-- ===== サービス ===== -->
    <section class="section service-section">
      <div class="container">
        <h2 class="section-heading reveal">SERVICES</h2>
        <div class="service-visual-grid reveal-stagger">
          <a href="/ai-consulting" class="sv-card gradient-border">
            <div class="sv-icon-wrap">
              <i class="fa-solid fa-magnifying-glass-chart"></i>
            </div>
            <h3>AI診断</h3>
            <p>あなたの業務のどこにAIが効くかを可視化する</p>
            <span class="sv-arrow">→</span>
          </a>
          <a href="/ai-consulting" class="sv-card gradient-border">
            <div class="sv-icon-wrap">
              <i class="fa-solid fa-handshake-angle"></i>
            </div>
            <h3>AI顧問</h3>
            <p>導入から定着まで月次で伴走するパートナー</p>
            <span class="sv-arrow">→</span>
          </a>
          <a href="/ai-consulting" class="sv-card gradient-border">
            <div class="sv-icon-wrap">
              <i class="fa-solid fa-chalkboard-user"></i>
            </div>
            <h3>AI研修</h3>
            <p>スタッフが自分でAIを使いこなせる実践型プログラム</p>
            <span class="sv-arrow">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== Industries — Bento Grid ===== -->
    <section class="section industry-section">
      <div class="container">
        <h2 class="section-heading reveal">INDUSTRIES</h2>
        <p class="section-sub reveal">9業種のサンプルレポートを公開中</p>
        <div class="bento-grid reveal-stagger">
          <a href="/ai-consulting/sample-pension" class="bento-item bento-lg gradient-border">
            <i class="fa-solid fa-bed"></i>
            <span>ペンション・宿泊業</span>
          </a>
          <a href="/ai-consulting/sample-restaurant" class="bento-item gradient-border">
            <i class="fa-solid fa-utensils"></i>
            <span>カフェ＆レストラン</span>
          </a>
          <a href="/ai-consulting/sample-construction" class="bento-item gradient-border">
            <i class="fa-solid fa-helmet-safety"></i>
            <span>工務店・建設業</span>
          </a>
          <a href="/ai-consulting/sample-winery" class="bento-item bento-lg gradient-border">
            <i class="fa-solid fa-wine-glass"></i>
            <span>ワイナリー・醸造所</span>
          </a>
          <a href="/ai-consulting/sample-outdoor" class="bento-item gradient-border">
            <i class="fa-solid fa-mountain-sun"></i>
            <span>アウトドアガイド</span>
          </a>
          <a href="/ai-consulting/sample-bakery" class="bento-item gradient-border">
            <i class="fa-solid fa-bread-slice"></i>
            <span>パン屋・ベーカリー</span>
          </a>
          <a href="/ai-consulting/sample-farmer" class="bento-item gradient-border">
            <i class="fa-solid fa-seedling"></i>
            <span>個人農家</span>
          </a>
          <a href="/ai-consulting/sample-dairy" class="bento-item gradient-border">
            <i class="fa-solid fa-cow"></i>
            <span>酪農・畜産業</span>
          </a>
          <a href="/ai-consulting/sample-municipality" class="bento-item bento-lg gradient-border">
            <i class="fa-solid fa-landmark"></i>
            <span>自治体・市役所</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== Why Optiens — 大きなキーワード ===== -->
    <section class="section why-section">
      <div class="container">
        <div class="why-grid">
          <div class="why-item reveal">
            <span class="why-num">10+</span>
            <p>年のエンタープライズ<br/>システム開発実績</p>
          </div>
          <div class="why-item reveal">
            <span class="why-num">AI</span>
            <p>を自社事業で<br/>日常的に活用</p>
          </div>
          <div class="why-item reveal">
            <span class="why-num">全国</span>
            <p>地域の事業者に<br/>オンラインで伴走</p>
          </div>
        </div>
        <div class="text-center reveal" style="margin-top: 48px;">
          <a href="/about" class="link-arrow">Optiensについて詳しく →</a>
        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="cta-section">
      <div class="cta-glow"></div>
      <div class="container text-center" style="position:relative;z-index:1;">
        <h2 class="reveal">まずは無料AI診断から</h2>
        <p class="reveal">3分のフォーム入力で、あなたの事業に合った<br/>AI活用ポイントをレポートでお届けします。</p>
        <a href="/free-diagnosis" class="btn-primary cta-btn reveal">無料AI診断を受ける</a>
      </div>
    </section>
  </main>
</Layout>

<style>
/* =========================================
   共通
========================================= */
.container {
  width: min(1000px, 100% - 2rem);
  margin-inline: auto;
}
.text-center { text-align: center; }

.section {
  padding: clamp(80px, 12vw, 120px) 20px;
}

.section-heading {
  font-size: clamp(12px, 1.4vw, 14px);
  font-weight: 600;
  letter-spacing: .25em;
  text-align: center;
  color: var(--brand);
  margin: 0 0 48px;
}
.section-sub {
  text-align: center;
  color: var(--muted);
  font-size: clamp(13px, 1.6vw, 15px);
  margin: -36px 0 48px;
}

/* =========================================
   Hero
========================================= */
.hero {
  position: relative;
  width: 100%;
  min-height: 100svh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface);
  overflow: hidden;
}

.hero-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 20px;
  animation: hero-fade-in .8s ease-out;
}

@keyframes hero-fade-in {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

.hero-eyebrow {
  display: block;
  margin: 0 0 1rem;
  font-size: clamp(11px, 1.2vw, 13px);
  letter-spacing: .3em;
  text-transform: uppercase;
  color: var(--brand);
  font-weight: 500;
}

.hero-title {
  font-size: clamp(30px, 5vw, 60px);
  font-weight: 800;
  line-height: 1.12;
  letter-spacing: -.02em;
  color: var(--heading);
  margin: 0 0 1rem;
}

.hero-sub {
  font-size: clamp(15px, 2vw, 18px);
  color: var(--muted);
  margin: 0 0 2.5rem;
  font-weight: 400;
}

.hero-cta {
  font-size: clamp(14px, 1.6vw, 16px);
  padding: .85rem 2.4rem;
}

/* =========================================
   サービス — ビジュアルカード
========================================= */
.service-section {
  background: var(--surface-2);
}
.service-visual-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.sv-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  text-decoration: none;
  color: inherit;
  padding: 48px 28px 40px;
  background: var(--surface-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  transition: border-color .3s ease, box-shadow .3s ease, transform .3s ease;
  position: relative;
}
.sv-card:hover {
  border-color: var(--border-hover);
  box-shadow: var(--glow);
  transform: translateY(-4px);
}
.sv-icon-wrap {
  width: 64px;
  height: 64px;
  border-radius: 16px;
  background: rgba(91, 127, 255, .1);
  border: 1px solid rgba(91, 127, 255, .2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.6rem;
  color: var(--brand);
  margin-bottom: 24px;
  transition: transform .3s ease, background .3s ease;
}
.sv-card:hover .sv-icon-wrap {
  transform: scale(1.08);
  background: rgba(91, 127, 255, .16);
}
.sv-card h3 {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--heading);
  margin: 0 0 10px;
}
.sv-card p {
  font-size: .88rem;
  color: var(--muted);
  line-height: 1.6;
  margin: 0;
}
.sv-arrow {
  position: absolute;
  bottom: 16px;
  right: 20px;
  font-size: 1.1rem;
  color: var(--brand);
  opacity: 0;
  transform: translateX(-6px);
  transition: opacity .3s ease, transform .3s ease;
}
.sv-card:hover .sv-arrow {
  opacity: 1;
  transform: translateX(0);
}

@media (max-width: 768px) {
  .service-visual-grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .sv-card {
    padding: 32px 24px;
    flex-direction: row;
    text-align: left;
    gap: 20px;
  }
  .sv-icon-wrap {
    margin-bottom: 0;
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    font-size: 1.3rem;
  }
  .sv-card h3 { font-size: 1.05rem; }
}

/* =========================================
   Industries — Bento Grid
========================================= */
.industry-section {
  background: var(--surface);
}

.bento-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: minmax(120px, auto);
  gap: 16px;
}

.bento-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  text-decoration: none;
  color: inherit;
  padding: 28px 16px;
  background: var(--surface-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  transition: border-color .3s ease, box-shadow .3s ease, transform .3s ease;
}
.bento-item:hover {
  border-color: var(--border-hover);
  box-shadow: var(--glow);
  transform: translateY(-3px);
}

.bento-item i {
  font-size: 2rem;
  color: var(--brand);
  transition: transform .3s ease;
}
.bento-item:hover i {
  transform: scale(1.15);
}
.bento-item span {
  font-size: .85rem;
  font-weight: 600;
  color: var(--text);
  text-align: center;
}

/* Large bento items span 2 columns */
.bento-lg {
  grid-column: span 2;
  flex-direction: row;
  gap: 16px;
  padding: 32px;
}
.bento-lg i { font-size: 2.2rem; }
.bento-lg span { font-size: .95rem; }

@media (max-width: 768px) {
  .bento-grid {
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: minmax(100px, auto);
  }
  .bento-lg { grid-column: span 2; }
}
@media (max-width: 480px) {
  .bento-grid {
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .bento-item { padding: 20px 12px; }
  .bento-lg { padding: 24px 16px; }
}

/* =========================================
   Why Optiens — 大きな数字セクション
========================================= */
.why-section {
  background: var(--surface-2);
}
.why-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
  text-align: center;
}
.why-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.why-num {
  font-size: clamp(36px, 5vw, 56px);
  font-weight: 800;
  letter-spacing: -.02em;
  background: linear-gradient(135deg, var(--brand) 0%, var(--titanium-light, #6BABC2) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}
.why-item p {
  font-size: .9rem;
  color: var(--muted);
  line-height: 1.6;
  margin: 0;
}

.link-arrow {
  display: inline-block;
  font-size: .9rem;
  font-weight: 600;
  color: var(--brand);
  text-decoration: none;
  transition: opacity .2s;
}
.link-arrow:hover { opacity: .75; }

@media (max-width: 600px) {
  .why-grid { grid-template-columns: 1fr; gap: 40px; }
}

/* =========================================
   CTA
========================================= */
.cta-section {
  position: relative;
  background: var(--surface-3);
  padding: clamp(80px, 12vw, 120px) 20px;
  overflow: hidden;
}
.cta-glow {
  position: absolute;
  width: 500px;
  height: 500px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(91, 127, 255, .08) 0%, transparent 70%);
  pointer-events: none;
}
.cta-section h2 {
  color: var(--heading);
  font-size: clamp(22px, 3.2vw, 32px);
  margin: 0 0 16px;
}
.cta-section p {
  color: var(--muted);
  margin: 0 0 32px;
  line-height: 1.8;
  font-size: clamp(14px, 1.6vw, 16px);
}
.cta-btn {
  font-size: clamp(14px, 1.6vw, 16px);
  padding: .85rem 2.5rem;
}

/* =========================================
   Responsive
========================================= */
@media (max-width: 768px) {
  .hero { min-height: auto; padding: 120px 16px 64px; }
}
@media (max-width: 640px) {
  .hero-title { font-size: clamp(24px, 7vw, 36px); }
}
</style>
