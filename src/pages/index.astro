---
import Layout from '../layouts/Layout.astro';
import backgroundUrl from '../assets/ai-nature-city.webp?url';
---

<Layout 
  title="Optiens | IoT×AIで実現する次世代ハーブ生産"
  description="IoTセンサーとAIで水耕栽培を自動化し、高品質なバジル・マイクログリーンを生産するOptiensの公式ウェブサイトです。"
>
  <main>
    <section class="hero-container" style={`--hero-bg: url(${backgroundUrl});`}>
      <div class="hero-content">
        <!-- 追加：見出し塊を中央寄せする shrink-to-fit ラッパー -->
        <div class="hero-lockup">
          <p class="eyebrow">GRAND VISION</p>
          <p class="hero-lead hero-lead--xl">
            DESIGNING A FUTURE WHERE PEOPLE<br/>
            AND THE PLANET THRIVE TOGETHER.
          </p>
          <p class="hero-lead hero-lead--sm">
            人と地球が共に豊かになる未来をデザインする。
          </p>
        </div>
      </div>
    </section>


    <section class="about-content-section">
      <div class="container">
        <div class="philosophy-grid">
          <div class="grid-item">
            <h2>持続可能な<span class="text-future">未来</span>のために</h2>
            <p>"円相" の哲学を基盤に、IoTとAIで水耕栽培を自動化し、持続可能な生産の仕組みを実装します。</p>
          </div>
        </div>

        <div class="values-section">
          <div class="values-grid">
            <div class="value-item value-item-harmony">
              <div class="value-icon-wrapper">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2Zm0 2a8 8 0 1 1 0 16A8 8 0 0 1 12 4Zm0 4a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z" fill="currentColor"/>
                  <path d="M12 18v4M12 2v4M18 12h4M2 12h4" stroke="#ea4335" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3>調和</h3>
              <p>競争から協調へ、所有から共有へ、分離から統合へ。人・自然・テクノロジーが調和できる社会を築きます。</p>
            </div>

            <div class="value-item value-item-optimization">
              <div class="value-icon-wrapper">
                <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
                  <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10Z" fill="#4285f4"/>
                  <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 2C6.477 2 2 6.477 2 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 6v12M18 12H6" stroke="#ea4335" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3>最適化</h3>
              <p>センサーデータやAI技術を活用した効率化と、常識の再定義により農業の新しいカタチを創造します。</p>
            </div>

            <div class="value-item value-item-cycle">
              <div class="value-icon-wrapper">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10Zm0-18a8 8 0 1 1 0 16A8 8 0 0 1 12 4Z" fill="currentColor"/>
                  <path d="M12 18v4M12 2v4M18 12h4M2 12h4" stroke="#ea4335" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="m12 12 4 4m-4-4-4 4m4-4 4-4m-4 4-4-4" stroke="#ea4335" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3>循環</h3>
              <p>資源もデータも種子も循環させ、気候リスクや輸入依存に左右されない、自律した食料生産を構築します。</p>
            </div>
          </div>
        </div>

      </div>
    </section>

  </main>
</Layout>

<style>
/* =========================================
   Global tokens
========================================= */
:root{
  /* 見出しブロックの最大行長（必要に応じて調整） */
  --hero-measure: clamp(36rem, 84vw, 96rem);

  /* 色・共通トークン（フォールバック付き） */
  --brand: #2e574c;
  --brand-2: #5ea89a;
  --brand-gradient: linear-gradient(135deg,#2e574c,#5ea89a);

  --surface: #fff;
  --surface-2: #f9f9f9;
  --text: #1a1a1a;
  --heading: #111;
  --muted: #6b7280;

  --radius: 10px;
  --shadow-sm: 0 8px 24px rgba(0,0,0,.06);
}

/* =========================================
   Hero（共通）
   - テキストは左寄せ
   - ブロック幅を揃えて中央に配置（wrapper不要）
========================================= */
.hero-container{
  position: relative;
  width: 100%;
  min-height: 100svh;
  padding: 80px 20px;

  display: flex;
  align-items: center;
  justify-content: center;

  /* 背景画像 + グラデのフォールバック */
  background-image: var(--hero-bg), var(--brand-gradient);
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;

  color: var(--on-hero, #fff);
  text-shadow: 0 2px 10px rgba(0,0,0,.35);
  overflow: hidden;
}
.hero-container::before{
  content:"";
  position:absolute; inset:0;
  background: rgba(0,0,0,.45);
  z-index:0;
}

/* 中央寄せはここで実現。子要素を同じ幅にして中央へ */
.hero-content{
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 20px;

  display: grid;
  justify-items: center;      /* 子要素を中央へ */
  row-gap: 0;                 /* 余白は各要素側で管理 */
}

/* Hero内の主要要素は同じ幅 (= 左端が揃う) */
.hero-content > .eyebrow,
.hero-content > .hero-lead,
.hero-content > .hero-cta{
  width: min(100%, var(--hero-measure));
  margin-inline: auto;
}

/* Eyebrow（小見出し）：左寄せ＆見出しと同じ開始位置 */
.eyebrow{
  display:block;
  margin:0 0 .75rem;
  text-align:left;
  font-size: clamp(12px, 1.2vw, 14px);
  letter-spacing:.18em;
  text-transform: uppercase;
  opacity:.9;
  color: color-mix(in srgb, var(--surface, #fff) 92%, black);
}

/* 見出し（左寄せ。ブロック自体は中央） */
.hero-lead{
  margin:0 0 1em;
  font-weight:800;
  line-height:1.3;
  text-align:left;
  text-wrap: balance;
}
.hero-lead--xl{
  font-size: clamp(28px, 4.2vw, 44px);
  line-height:1.18;
  letter-spacing:.02em;
}
.hero-lead--sm{
  text-align: right;
  font-size: clamp(16px, 2.2vw, 20px);
  font-weight:700;
  opacity:.95;
}

/* CTA（任意） */
.hero-cta{
  display:inline-block;
  padding:14px 32px;
  background: var(--brand-gradient);
  color:#fff;
  font-weight:700;
  border-radius:8px;
  transition: transform .2s ease, box-shadow .2s ease;
}
.hero-cta:hover{ transform: translateY(-2px); box-shadow:0 6px 16px rgba(0,0,0,.2); }
.hero-cta:focus-visible{
  outline:3px solid color-mix(in srgb, var(--brand) 40%, white);
  outline-offset:3px;
}

/* =========================================
   About 内の“ミニ・ヒーロー” 変種
========================================= */
.hero-container--inline{
  min-height:auto;
  padding: clamp(24px, 4vw, 40px);
  margin-bottom: 48px;

  background: var(--surface);
  border: 1px solid color-mix(in srgb, var(--brand-2) 22%, transparent);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
  text-shadow:none;
  color: var(--text);
}
.hero-container--inline::before{ display:none; }  /* 暗幕は不要 */
.hero-container--inline .eyebrow{ color: var(--brand-2); }
.hero-container--inline .hero-lead{ color: var(--heading); }
.hero-container--inline .hero-lead--sm{ color: var(--muted); font-weight:600; }

/* =========================================
   Content blocks
========================================= */
.about-content-section{
  padding:64px 20px;
  background: var(--surface);
  line-height:1.8;
}
.container{
  width:min(1000px, 100% - 2rem);
  margin-inline:auto;
}

.text-future{ color:#ea4335; }

.philosophy-grid{
  display:grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap:40px;
  margin-bottom:60px;
}
.grid-item h2{
  font-size: clamp(24px, 3.4vw, 36px);
  color: var(--heading);
  margin:0 0 20px;
  padding-bottom:10px;
  border-bottom:2px solid color-mix(in srgb, #000 12%, transparent);
}
.grid-item p{ margin:0; }

.values-section h2{
  font-size: clamp(24px, 3.4vw, 36px);
  color: var(--heading);
  text-align:center;
  margin:0 0 40px;
  padding-bottom:10px;
  border-bottom:2px solid color-mix(in srgb, #000 12%, transparent);
}
.values-grid{
  display:grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap:30px;
}
.value-item{
  background: var(--surface);
  padding:30px;
  border-radius:10px;
  box-shadow: 0 4px 15px rgba(0,0,0,.05);
  transition: transform .3s ease, box-shadow .3s ease;
  display:flex; flex-direction:column; align-items:center;
}
.value-item:hover{ transform: translateY(-5px); box-shadow:0 8px 25px rgba(0,0,0,.1); }

.value-icon-wrapper{
  width:60px; height:60px; margin-bottom:20px;
  border-radius:50%;
  display:grid; place-items:center;
  color:#fff; /* currentColor 用 */
}
.value-item-harmony .value-icon-wrapper{ background:#fbbc04; }
.value-item-optimization .value-icon-wrapper{ background:#4285f4; }
.value-item-cycle .value-icon-wrapper{ background:#5bb974; }
.value-icon-wrapper svg{ width:30px; height:30px; }
.value-icon-wrapper svg path[fill="currentColor"]{ fill: currentColor; }
.value-icon-wrapper svg path[stroke="currentColor"]{ stroke: currentColor; }

.value-item h3{
  font-size:1.5em;
  font-weight:700;
  color: var(--text);
  margin:0 0 10px;
}
.value-item p{
  font-size:1em;
  margin:0;
  text-align:left;
}

/* =========================================
   Responsive / A11y
========================================= */
@media (max-width: 768px){
  .about-content-section{ padding:52px 20px; }
  .hero-content{ padding:64px 20px; }
  .hero-content > .eyebrow,
  .hero-content > .hero-lead,
  .hero-content > .hero-cta{
    width: min(92vw, var(--hero-measure));
  }
  .hero-lead--xl{ hyphens:auto; word-break:normal; }
}
@media (prefers-reduced-motion: reduce){
  .about-hero-section video{ display:none; }
}

@media (max-width: 640px){

  /* 補足文（日本語1行）のスタイル */
  .hero-lead--sm{
    text-align: center;      /* モバイルは中央 */
    white-space: nowrap;     /* 改行させない */
    overflow: hidden;        /* 念のためオーバーフロー対策 */
    text-overflow: clip;     /* はみ出しを切り捨て（…にしたいなら ellipsis） */

    /* 横幅に合わせて自動縮小（22 は文の文字数、40px は左右の padding 合計） */
    font-size: clamp(14px, calc((100vw - 40px) / 22), 18px);
  }
}


</style>
