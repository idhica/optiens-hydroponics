---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="書類添削ツール（デモ）| Optiens"
  description="部下が作成した社内文書を上長が添削するための業務ツールのデモです。各行ごとにメモを書き込み、添削箇所を一覧で管理できます。"
  canonical="https://optiens.com/document-editor"
>
  <main class="ed-main light-section">
    <!-- ヒーロー -->
    <section class="ed-hero">
      <div class="container text-center">
        <p class="hero-eyebrow">DEMO</p>
        <h1>書類添削ツール（デモ）</h1>
        <p class="hero-sub">
          部下が作成した社内文書を上長が添削するための業務用ツールです。<br />
          各行ごとにメモを書き込み、添削した箇所を一覧で管理できます。
        </p>
      </div>
    </section>

    <!-- ツール本体 -->
    <section class="ed-tool-section">
      <div class="container">
        <!-- ツールバー -->
        <div class="toolbar">
          <div class="toolbar-left">
            <span class="toolbar-title">書類添削ツール</span>
            <select id="doc-select">
              <option value="">社内文書を選択</option>
            </select>
          </div>
          <div class="toolbar-right">
            <span id="status" class="status"></span>
            <button type="button" id="save-btn-top" class="action-btn primary" disabled>
              <i class="fa-solid fa-floppy-disk"></i> 保存
            </button>
            <button type="button" id="clear-btn" class="action-btn danger" disabled>クリア</button>
          </div>
        </div>

        <!-- 空状態 -->
        <div id="empty-state" class="empty-state">
          <p>左上のメニューから書類を選択してください。</p>
          <p class="empty-hint">サンプルは社内文書を想定したダミーデータです。本番環境では御社のDBから直接選択する仕組みを構築できます。</p>
        </div>

        <!-- エディタ -->
        <div id="editor" class="editor" style="display:none;">
          <div class="editor-header">
            <div class="col-header col-header-num">#</div>
            <div class="col-header col-header-text">本文</div>
            <div class="col-header col-header-note">添削メモ</div>
          </div>
          <div id="editor-body" class="editor-body"></div>
        </div>

        <!-- 下部の保存ボタン -->
        <div id="bottom-actions" class="bottom-actions" style="display:none;">
          <span id="status-bottom" class="status-bottom"></span>
          <button type="button" id="save-btn-bottom" class="action-btn primary">
            <i class="fa-solid fa-floppy-disk"></i> 保存
          </button>
        </div>

        <!-- 注意書き -->
        <p class="disclaimer">
          ※添削メモはお使いのブラウザに保存されます（他端末・他ブラウザには引き継がれません）。<br />
          ※御社専用版では、社内Slack/Teams連携・添削履歴のチーム共有・AIによる事前チェック等の拡張が可能です。
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="ed-cta-section">
      <div class="container text-center">
        <h2>御社業務に合わせたカスタム版もご相談いただけます</h2>
        <p>
          複数人での共有・添削履歴の管理・社内テンプレート照合など、<br />
          御社の業務フローに沿った仕組みを構築します。
        </p>
        <div class="cta-buttons">
          <a href="/free-diagnosis" class="btn-primary">無料AI診断を受ける（0円）</a>
          <a href="/service" class="btn-ghost">サービスメニューを見る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  interface SampleDoc {
    id: string;
    title: string;
    category: string;
    text: string;
  }

  const STORAGE_PREFIX = 'optiens:document-review:';

  const docSelect = document.getElementById('doc-select') as HTMLSelectElement;
  const saveBtnTop = document.getElementById('save-btn-top') as HTMLButtonElement;
  const saveBtnBottom = document.getElementById('save-btn-bottom') as HTMLButtonElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
  const statusEl = document.getElementById('status') as HTMLSpanElement;
  const statusBottom = document.getElementById('status-bottom') as HTMLSpanElement;
  const emptyState = document.getElementById('empty-state') as HTMLDivElement;
  const editor = document.getElementById('editor') as HTMLDivElement;
  const editorBody = document.getElementById('editor-body') as HTMLDivElement;
  const bottomActions = document.getElementById('bottom-actions') as HTMLDivElement;

  let samples: SampleDoc[] = [];
  let currentDocId = '';
  let currentLines: string[] = [];
  let dirty = false;

  // --- サンプル読み込み ---
  async function loadSamples() {
    try {
      const res = await fetch('/samples/document-editor.json');
      samples = await res.json();
      docSelect.innerHTML = '<option value="">社内文書を選択</option>';
      const byCategory: Record<string, SampleDoc[]> = {};
      for (const s of samples) {
        const list = byCategory[s.category] ?? (byCategory[s.category] = []);
        list.push(s);
      }
      for (const [category, docs] of Object.entries(byCategory)) {
        const group = document.createElement('optgroup');
        group.label = category;
        for (const doc of docs) {
          const o = document.createElement('option');
          o.value = doc.id;
          o.textContent = doc.title;
          group.appendChild(o);
        }
        docSelect.appendChild(group);
      }
    } catch {
      statusEl.textContent = 'サンプルの読み込みに失敗しました';
    }
  }

  // --- 書類選択 ---
  docSelect.addEventListener('change', () => {
    if (dirty && !confirm('保存していない変更があります。破棄して切り替えますか？')) {
      docSelect.value = currentDocId;
      return;
    }
    const id = docSelect.value;
    if (!id) {
      showEmptyState();
      return;
    }
    const doc = samples.find(s => s.id === id);
    if (!doc) return;
    currentDocId = id;
    const savedMemos = loadMemos(id);
    renderRows(doc.text, savedMemos);
  });

  // --- localStorage ---
  function loadMemos(docId: string): Record<number, string> {
    try {
      const raw = localStorage.getItem(STORAGE_PREFIX + docId);
      if (!raw) return {};
      return JSON.parse(raw);
    } catch {
      return {};
    }
  }
  function saveMemos(docId: string, memos: Record<number, string>) {
    try {
      localStorage.setItem(STORAGE_PREFIX + docId, JSON.stringify(memos));
      return true;
    } catch {
      return false;
    }
  }

  // --- レンダリング ---
  function renderRows(text: string, savedMemos: Record<number, string> = {}) {
    const lines = text.split('\n');
    currentLines = lines;
    editorBody.innerHTML = '';

    lines.forEach((line, i) => {
      const row = document.createElement('div');
      row.className = 'row';
      row.dataset.lineIndex = String(i);

      const num = document.createElement('div');
      num.className = 'row-num';
      num.textContent = String(i + 1);

      const textEl = document.createElement('div');
      textEl.className = 'row-text';
      if (line.trim() === '') {
        textEl.innerHTML = '<span class="row-text-empty">（空行）</span>';
      } else {
        textEl.textContent = line;
      }

      const noteCell = document.createElement('textarea');
      noteCell.className = 'row-note';
      noteCell.placeholder = '';
      noteCell.value = savedMemos[i] || '';
      noteCell.rows = 1;
      noteCell.spellcheck = false;

      const updateRowState = () => {
        const hasNote = noteCell.value.trim().length > 0;
        row.classList.toggle('has-note', hasNote);
      };

      const resize = () => {
        noteCell.style.height = 'auto';
        const h = Math.max(textEl.offsetHeight, noteCell.scrollHeight);
        noteCell.style.height = h + 'px';
      };

      noteCell.addEventListener('input', () => {
        updateRowState();
        resize();
        markDirty();
      });
      noteCell.addEventListener('focus', () => row.classList.add('focused'));
      noteCell.addEventListener('blur', () => row.classList.remove('focused'));

      row.appendChild(num);
      row.appendChild(textEl);
      row.appendChild(noteCell);
      editorBody.appendChild(row);

      updateRowState();
      requestAnimationFrame(() => {
        const h = Math.max(textEl.offsetHeight, noteCell.scrollHeight);
        textEl.style.minHeight = h + 'px';
        noteCell.style.height = h + 'px';
      });
    });

    emptyState.style.display = 'none';
    editor.style.display = 'block';
    bottomActions.style.display = 'flex';
    saveBtnTop.disabled = false;
    clearBtn.disabled = false;
    dirty = false;
    updateStatus();
  }

  // --- メモ収集 ---
  function collectMemos(): Record<number, string> {
    const memos: Record<number, string> = {};
    editorBody.querySelectorAll('.row').forEach((row) => {
      const idx = parseInt((row as HTMLElement).dataset.lineIndex || '0', 10);
      const v = ((row.querySelector('.row-note') as HTMLTextAreaElement).value || '').trim();
      if (v) memos[idx] = v;
    });
    return memos;
  }

  // --- 保存 ---
  function doSave() {
    if (!currentDocId) return;
    const memos = collectMemos();
    const ok = saveMemos(currentDocId, memos);
    if (ok) {
      dirty = false;
      updateStatus('保存しました');
      // 1.5秒後に通常表示に戻す
      setTimeout(() => updateStatus(), 1500);
    } else {
      updateStatus('保存に失敗しました');
    }
  }
  saveBtnTop.addEventListener('click', doSave);
  saveBtnBottom.addEventListener('click', doSave);

  // --- ダーティ管理 ---
  function markDirty() {
    if (!dirty) {
      dirty = true;
      updateStatus();
    }
  }

  function updateStatus(message?: string) {
    if (message) {
      statusEl.textContent = message;
      statusBottom.textContent = message;
      saveBtnTop.classList.remove('warn');
      saveBtnBottom.classList.remove('warn');
      return;
    }
    const memoCount = editorBody.querySelectorAll('.row.has-note').length;
    const dirtyMark = dirty ? ' ・未保存の変更あり' : '';
    const text = `${currentLines.length}行 / ${memoCount}件のメモ${dirtyMark}`;
    statusEl.textContent = text;
    statusBottom.textContent = text;
    saveBtnTop.classList.toggle('warn', dirty);
    saveBtnBottom.classList.toggle('warn', dirty);
  }

  // --- クリア ---
  clearBtn.addEventListener('click', () => {
    if (dirty && !confirm('保存していない変更があります。破棄しますか？')) return;
    docSelect.value = '';
    currentDocId = '';
    showEmptyState();
  });

  function showEmptyState() {
    emptyState.style.display = 'block';
    editor.style.display = 'none';
    bottomActions.style.display = 'none';
    saveBtnTop.disabled = true;
    clearBtn.disabled = true;
    dirty = false;
    statusEl.textContent = '';
    statusBottom.textContent = '';
    currentLines = [];
  }

  // --- 離脱時の警告 ---
  window.addEventListener('beforeunload', (e) => {
    if (dirty) {
      e.preventDefault();
      e.returnValue = '';
    }
  });

  loadSamples();
</script>

<style>
  .ed-main {
    padding-top: 80px;
  }

  /* ヒーロー */
  .ed-hero {
    padding: clamp(40px, 6vw, 64px) 0 clamp(24px, 4vw, 40px);
    background: var(--surface);
  }
  .hero-eyebrow {
    font-size: clamp(11px, 1.2vw, 13px);
    font-weight: 600;
    letter-spacing: .25em;
    color: var(--brand);
    margin: 0 0 12px;
    text-transform: uppercase;
  }
  .ed-hero h1 {
    color: var(--heading);
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    margin: 0 0 16px;
  }
  .ed-hero .hero-sub {
    color: var(--muted);
    font-size: clamp(.9rem, 1.6vw, 1.05rem);
    line-height: 1.85;
    margin: 0 auto;
    max-width: 720px;
  }

  /* ツール本体 */
  .ed-tool-section {
    padding: clamp(32px, 5vw, 48px) 0 clamp(48px, 6vw, 72px);
    background: var(--surface-2);
  }

  /* ツールバー */
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    padding: 14px 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    margin-bottom: 16px;
  }
  .toolbar-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--heading);
    white-space: nowrap;
  }
  .toolbar-left, .toolbar-right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .toolbar select {
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.88rem;
    background: var(--surface);
    color: var(--text);
    min-width: 220px;
  }
  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border: 1px solid transparent;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity .2s, transform .2s, background-color .2s;
  }
  .action-btn:hover { opacity: .9; transform: translateY(-1px); }
  .action-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
  .action-btn.primary {
    background: var(--brand);
    color: #fff;
  }
  .action-btn.primary.warn {
    background: #F24E1E;
    animation: pulseSave 1.5s ease-in-out infinite;
  }
  @keyframes pulseSave {
    0%, 100% { box-shadow: 0 0 0 0 rgba(242, 78, 30, 0.5); }
    50% { box-shadow: 0 0 0 6px rgba(242, 78, 30, 0); }
  }
  .action-btn.danger {
    background: transparent;
    color: var(--muted);
    border-color: var(--border);
  }
  .status, .status-bottom {
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
  }

  /* 空状態 */
  .empty-state {
    text-align: center;
    padding: 64px 20px;
    background: var(--surface);
    border: 1px dashed var(--border);
    border-radius: 10px;
    color: var(--muted);
  }
  .empty-state p { margin: 0; }
  .empty-hint {
    font-size: 0.85rem;
    margin-top: 12px !important;
    line-height: 1.7;
  }

  /* エディタ */
  .editor {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }
  .editor-header {
    display: grid;
    grid-template-columns: 48px 1fr 1fr;
    background: var(--brand);
    color: #fff;
  }
  .col-header {
    padding: 10px 14px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .col-header-num { text-align: center; }
  .col-header-note { border-left: 1px solid rgba(255, 255, 255, 0.2); }

  /* 行 */
  .row {
    display: grid;
    grid-template-columns: 48px 1fr 1fr;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s ease;
  }
  .row:last-child { border-bottom: none; }
  .row:hover { background: rgba(162, 89, 255, 0.04); }
  .row.focused { background: rgba(162, 89, 255, 0.08); }

  /* メモがある行: 本文を赤字に */
  .row.has-note .row-text {
    color: #d33028;
    text-decoration: line-through;
    text-decoration-color: rgba(211, 48, 40, 0.5);
  }
  .row.has-note .row-num {
    color: #d33028;
    font-weight: 700;
  }
  .row.has-note { background: rgba(211, 48, 40, 0.03); }

  .row-num {
    padding: 10px 4px;
    font-size: 0.72rem;
    color: var(--muted);
    text-align: center;
    user-select: none;
    border-right: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12px;
    font-family: 'SF Mono', 'Consolas', 'Monaco', monospace;
  }
  .row-text {
    padding: 10px 14px;
    font-size: 0.92rem;
    line-height: 1.85;
    word-break: break-word;
    border-right: 1px solid var(--border);
    color: var(--text);
    white-space: pre-wrap;
    transition: color 0.2s ease;
  }
  .row-text-empty {
    color: var(--muted);
    font-size: 0.78rem;
    opacity: 0.6;
  }
  .row-note {
    padding: 10px 14px;
    font-size: 0.88rem;
    line-height: 1.75;
    border: none;
    background: transparent;
    resize: none;
    overflow: hidden;
    font-family: inherit;
    color: var(--text);
    width: 100%;
    box-sizing: border-box;
  }
  .row-note:focus {
    outline: none;
    background: rgba(162, 89, 255, 0.04);
  }
  .row-note::placeholder { color: transparent; }
  .row:hover .row-note::placeholder {
    color: var(--muted);
    opacity: 0.4;
  }

  /* 下部の保存アクション */
  .bottom-actions {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 14px;
    margin-top: 16px;
    padding: 14px 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
  }

  /* 注意書き */
  .disclaimer {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.85;
    margin: 24px 0 0;
    padding: 14px 18px;
    background: var(--surface);
    border-left: 3px solid var(--brand);
    border-radius: 0 6px 6px 0;
  }

  /* CTA */
  .ed-cta-section {
    padding: clamp(48px, 7vw, 80px) 0;
    background: var(--surface);
  }
  .ed-cta-section h2 {
    color: var(--heading);
    font-size: clamp(1.2rem, 3vw, 1.7rem);
    margin: 0 0 16px;
  }
  .ed-cta-section p {
    color: var(--muted);
    font-size: clamp(.9rem, 1.5vw, 1rem);
    line-height: 1.85;
    margin: 0 0 28px;
  }
  .cta-buttons {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* スマホ */
  @media (max-width: 768px) {
    .toolbar { padding: 12px 14px; }
    .toolbar-left, .toolbar-right { width: 100%; }
    .toolbar-right { justify-content: flex-end; }
    .toolbar select { min-width: 0; flex: 1; }
    .action-btn { padding: 7px 12px; font-size: 0.8rem; }

    .editor-header { grid-template-columns: 36px 1fr 1fr; }
    .row { grid-template-columns: 36px 1fr 1fr; }
    .row-num { font-size: 0.68rem; padding-top: 10px; }
    .row-text { font-size: 0.85rem; padding: 8px 10px; }
    .row-note { font-size: 0.82rem; padding: 8px 10px; }
  }
  @media (max-width: 480px) {
    .editor-header { grid-template-columns: 30px 1fr 1fr; }
    .row { grid-template-columns: 30px 1fr 1fr; }
    .row-text { font-size: 0.8rem; padding: 6px 8px; }
    .row-note { font-size: 0.78rem; padding: 6px 8px; }
  }
</style>
