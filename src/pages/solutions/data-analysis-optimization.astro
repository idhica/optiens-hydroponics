---
import Layout from '../../layouts/Layout.astro';
import dataAnalysisImg from '~/assets/data-analysis-optimization.png';

export const solutionData = {
  title: 'AquaLoop Platform — 遠隔監視・運用SaaS',
  badge: 'SaaS',
  overview: 'AquaLoopハードウェアと一体で提供する遠隔監視・最適化SaaS。稼働率保証・障害予兆検知・SLAレポーティングで、物流困難な拠点でも継続稼働を支えます。',
  image: dataAnalysisImg,
};
---

<Layout title={`${solutionData.title} | Optiens`}>
  <main>
    <section class="solution-detail-container">
      <div class="container">
        <div class="solution-badge">{solutionData.badge}</div>
        <h1 class="solution-title">{solutionData.title}</h1>

        <div class="solution-thumbnail-wrapper">
          <img src={solutionData.image.src} alt={solutionData.title} class="solution-thumbnail" />
        </div>

        <div class="solution-body prose">
          <section>
            <h2>稼働状態の可視化とボトルネック検出</h2>
            <p>センサーから収集した温度・湿度・EC/pH・消費電力などの時系列データをダッシュボードで常時可視化します。AIがパターン異常を検出し、障害の予兆をアラートで通知。これまで見えなかった非効率な運転条件を特定し、具体的な改善施策を提案します。</p>
          </section>

          <section>
            <h2>エネルギー・資源効率の継続的最適化</h2>
            <p>照明・給液・空調の制御パラメータをAIが自動チューニングし、kWh/kg指標を段階的に改善します。廃液量・水循環率・電力コスト比率を定量的に管理し、SLAレポートとして定期提供します。</p>
          </section>

          <section>
            <h2>遠隔監視とSLA対応</h2>
            <p>AquaLoopプラットフォームの一部として、オンサイト対応を最小化する遠隔運用設計。障害発生時はMTTR（平均復旧時間）24時間以内を目標にリモートサポートを提供します。稼働率・障害履歴・改善提案を含む月次レポートをSaaS内で提供します。</p>
          </section>

          <section>
            <h2>運用ノウハウの蓄積と継続改善</h2>
            <p>各拠点の運用データを継続蓄積し、作物種別・環境条件別の最適制御パターンを積み上げます。蓄積されたノウハウはサービス改善に還元され、導入拠点の性能が時間とともに向上します。複数拠点への展開フェーズでは、拠点間の横断分析により全体最適化をさらに加速します。</p>
          </section>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .solution-badge {
    display: inline-block;
    background: var(--brand-2, #5ea89a);
    color: #fff;
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .08em;
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: .75rem;
  }
</style>
