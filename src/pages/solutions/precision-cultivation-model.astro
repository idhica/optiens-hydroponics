---
import Layout from '../../layouts/Layout.astro';
import precisionCultivationImg from '~/assets/precision-cultivation-model.png';

export const solutionData = {
  title: 'AquaLoop — AI駆動型 水耕栽培自動化モジュール',
  badge: 'R&D',
  overview: 'センサー・AI・SaaSを一体化した閉鎖循環型の水耕栽培モジュール。医療・防災・孤立環境に求められる安定稼働と遠隔管理を実現します。',
  image: precisionCultivationImg,
};
---

<Layout title={`${solutionData.title} | Optiens`}>
  <main>
    <section class="solution-detail-container">
      <div class="container">
        <div class="solution-badge">{solutionData.badge}</div>
        <h1 class="solution-title">{solutionData.title}</h1>

        <div class="solution-thumbnail-wrapper">
          <img src={solutionData.image.src} alt={solutionData.title} class="solution-thumbnail" />
        </div>

        <div class="solution-body prose">
          <section>
            <h2>AI制御による自律運転</h2>
            <p>光・温度・湿度・CO2・EC/pH・流量などの栽培環境データをAIがリアルタイムで統合解析し、制御パラメータを自動調整します。人手による日々のチューニングを不要にし、24時間365日の安定稼働を実現します。</p>
          </section>

          <section>
            <h2>閉鎖循環設計による安全性と再現性</h2>
            <p>外部環境から遮断された密閉系で、給排液・空調・照明を統合管理します。衛生基準が厳しい医療機関・防災拠点での運用に適した設計で、水循環率95%以上を目標に廃液を最小化します。</p>
          </section>

          <section>
            <h2>モジュール構造による柔軟な展開</h2>
            <p>シングルベイMVP（約0.5m²級）から始め、設置環境に応じてユニット単位で拡張可能な設計を採用。物流が困難な離島・地下施設・船舶などの孤立環境への設置も想定しています。ユニット交換方式でダウンタイムを最小化します。</p>
          </section>

          <section>
            <h2>運用SaaSとの一体提供</h2>
            <p>ハードウェアの販売・保守に加え、遠隔監視・アラート・稼働最適化・SLAレポーティングを含む運用SaaS（月額）をセットで提供します。設備を売って終わりではなく、運用データで継続的に学習する「生きたインフラ」として価値を提供し続けます。</p>
          </section>

          <section>
            <h2>主なターゲット</h2>
            <ul>
              <li>病院・介護施設：衛生管理が厳しい施設内での安定した食材・薬草供給</li>
              <li>防災拠点・自治体：非常時の食料自給と平時の連続稼働実証</li>
              <li>離島・船舶・地下施設：物流が困難な孤立環境での長期自律運用</li>
            </ul>
          </section>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .solution-badge {
    display: inline-block;
    background: var(--brand-2, #5ea89a);
    color: #fff;
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .08em;
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: .75rem;
  }
</style>
