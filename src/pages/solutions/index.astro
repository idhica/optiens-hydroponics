---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

// ヒーロー背景画像
import bgUrl from '~/assets/ai-nature-city.webp?url';

// 各ソリューション詳細ページからデータをインポート
import { solutionData as precisionCultivationModel } from './precision-cultivation-model.astro';
import { solutionData as dataAnalysisOptimization } from './data-analysis-optimization.astro';

type SolutionData = {
  title: string;
  overview: string;
  image: unknown; // ImageMetadata を推奨
};

const solutions: { slug: string; data: SolutionData }[] = [
  { slug: 'precision-cultivation-model', data: precisionCultivationModel as SolutionData },
  { slug: 'data-analysis-optimization', data: dataAnalysisOptimization as SolutionData },
];

const safeAlt = (s: string) =>
  (s && typeof s === 'string' && s.trim() ? s.trim() : 'Solution thumbnail');

const isImageMeta = (src: unknown) =>
  !!src && typeof src === 'object' && 'src' in (src as any) && 'width' in (src as any);
---

<Layout title="ソリューション | Optiens">
  <main>
    <!-- 共通 Hero セクション -->
    <section class="hero-section" style={`--hero-bg: url(${bgUrl});`}>
      <div class="container text-center">
        <h1>ソリューション</h1>
      </div>
    </section>

    <!-- ソリューション一覧 -->
    <section class="solutions-list-section">
      <div class="container">
        {solutions.length === 0 ? (
          <p class="no-solutions-message">近日公開のソリューションは準備中です。</p>
        ) : (
          <div class="solutions-grid">
            {solutions.map((solution) => {
              const href = `/solutions/${encodeURIComponent(solution.slug)}`;
              const d = solution.data;
              return (
                <article class="card solutions-item" key={solution.slug}>
                  <a href={href} class="solutions-item-link" aria-label={`${d.title} の詳細へ`}>
                    <div class="solutions-thumbnail-wrapper">
                      {isImageMeta(d.image) ? (
                        <Image
                          src={d.image as any}
                          alt={safeAlt(d.title)}
                          widths={[480, 640, 960]}
                          sizes="(max-width: 768px) 100vw, 33vw"
                          class="solutions-thumbnail"
                          loading="lazy"
                          decoding="async"
                        />
                      ) : (
                        <img
                          src={typeof d.image === 'string' ? d.image : ''}
                          alt={safeAlt(d.title)}
                          class="solutions-thumbnail"
                          loading="lazy"
                          decoding="async"
                        />
                      )}
                    </div>

                    <div class="card-content">
                      <h2 class="card-title">{d.title}</h2>
                      {d.overview && <p class="card-text">{d.overview}</p>}
                      <span class="card-icon-container" aria-hidden="true">
                        <i class="fa-solid fa-arrow-up-right-from-square"></i>
                      </span>
                    </div>
                  </a>
                </article>
              );
            })}
          </div>
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ========== Solutions List 固有部分 ========== */
  .solutions-list-section {
    padding: clamp(32px, 6vw, 60px) 0;
  }
  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    max-width: 800px;
    margin: 0 auto;
  }
  @media (max-width: 600px) {
    .solutions-grid {
      grid-template-columns: 1fr;
    }
  }
  .solutions-thumbnail-wrapper {
    height: 200px;
  }
  .solutions-thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .no-solutions-message {
    font-size: 1rem;
    color: var(--text,#1a1a1a);
    padding: 24px;
    background: var(--surface,#fff);
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0,0,0,.06);
    text-align: center;
  }
</style>
