---
import Layout from '../../layouts/Layout.astro';
import { newsArticles } from '../../data/news';

const { slug } = Astro.params;
const article = newsArticles.find((a) => a.slug === slug);

if (!article) {
  return Astro.redirect('/404');
}
---

<Layout title={`${article.title} | Optiens`}>
  <main>
    <section class="news-detail-container">
      <div class="container">
        <article class="news-article">
          <h1 class="news-title">{article.title}</h1>
          <p class="news-date">{article.date.replace(/-/g, '.')}</p>
          <div class="news-body prose" set:html={article.body} />
        </article>
        <div class="back-link">
          <a href="/news" class="btn-back">← ニュース一覧へ</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .news-detail-container {
    padding: clamp(80px, 10vw, 120px) 20px 60px;
  }
  .container {
    max-width: 800px;
    margin: 0 auto;
  }
  .news-article {
    background: var(--surface, #fff);
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,.08);
  }
  .news-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: bold;
    color: var(--heading, #111);
    margin: 0 0 .5rem;
  }
  .news-date {
    font-size: .9rem;
    color: var(--muted, #666);
    margin: 0 0 2rem;
    display: block;
  }
  .news-body :global(h2) {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--heading, #111);
    margin: 2.5rem 0 1rem;
  }
  .news-body :global(h3) {
    font-size: 1.2rem;
    font-weight: bold;
    color: var(--heading, #111);
    margin: 2rem 0 .75rem;
  }
  .news-body :global(p) {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text, #1a1a1a);
    margin: 0 0 1.5rem;
  }
  .news-body :global(ul),
  .news-body :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.5rem;
    line-height: 1.8;
  }
  .news-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 2rem 0;
  }
  .back-link {
    text-align: center;
    margin-top: 2rem;
  }
  .btn-back {
    display: inline-block;
    padding: 10px 24px;
    background: var(--brand, #2e574c);
    color: #fff;
    text-decoration: none;
    font-weight: bold;
    border-radius: 6px;
    transition: opacity .2s;
  }
  .btn-back:hover { opacity: .85; }
</style>
