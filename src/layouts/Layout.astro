---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '~/styles/global.css'; // ルートエイリアスでバンドル

export interface Props {
  title: string;
  description?: string;
  canonical?: string;                 // 例: https://optiens.com/solutions
  ogImage?: string;                   // 例: https://optiens.com/ogp.png (public 推奨)
  noindex?: boolean;                  // true のとき robots を noindex に
}

const {
  title,
  description = 'AIテクノロジーと自然の調和を通じて、人々と地球が共に豊かになる未来を追求するオプティエンスの公式ウェブサイトです。',
  canonical,
  ogImage,
  noindex = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="generator" content={Astro.generator} />

    {/* Canonical */}
    {canonical && <link rel="canonical" href={canonical} />}

    {/* Favicon / PWA 基本 */}
    <link rel="icon" type="image/svg+xml" href="/images/optiens-logo.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/images/optiens-logo.png" />
    <link rel="apple-touch-icon" href="/images/optiens-logo.png" />
    {/* (ある場合) */}
    {/* <link rel="manifest" href="/site.webmanifest" /> */}
    <meta name="theme-color" content="#0B2A4A" />

    {/* OGP / Twitter */}
    <meta property="og:site_name" content="Optiens" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    {/* Fonts */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap"
      rel="stylesheet"
    />

    {/* Icons (外部CSSはレンダーブロック注意。将来はSVG直書きやローカル配信推奨) */}
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    {/* 任意: Safari等の電話番号自動リンクを抑止したい場合 */}
    {/* <meta name="format-detection" content="telephone=no" /> */}
  </head>
  <body>
    {/* スキップリンク（キーボード利用者向け） */}
    <a href="#main" class="skip-link">本文へスキップ</a>

    <Header />
    <div id="main" class="site-main">
      <slot />
    </div>
    <Footer />
  </body>
</html>

<style is:global>
  /* アクセシビリティ: スキップリンクをフォーカス時だけ表示 */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    z-index: 1000;
    background: #0B2A4A;
    color: #fff;
    padding: 8px 12px;
    border-radius: 6px;
    text-decoration: none;
    transition: top .2s ease;
  }
  .skip-link:focus { top: 8px; }
</style>
