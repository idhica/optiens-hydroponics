---
<footer>
  <div class="container footer-inner">
    <div class="footer-top">
      <!-- ロゴ + 説明 -->
      <div class="footer-brand-col">
        <p class="footer-tagline">AIを事業の中心に。</p>
        <p class="footer-email"><a href="mailto:info@optiens.com">info@optiens.com</a></p>
        <a href="https://www.ipa.go.jp/security/security-action/" target="_blank" rel="noopener noreferrer" class="footer-badge-link">
          <img src="/images/badges/security-action-hitotsuboshi.png" alt="SECURITY ACTION 一つ星を宣言しました" class="footer-badge" width="80" height="80" />
        </a>
      </div>

      <!-- サービス -->
      <div class="footer-col">
        <p class="footer-col-heading">サービス</p>
        <ul>
          <li><a href="/ai-consulting">AI活用診断</a></li>
          <li><a href="/ai-consulting">AI顧問</a></li>
          <li><a href="/ai-consulting">AI研修</a></li>
          <li><a href="/ai-consulting#samples">サンプルレポート</a></li>
        </ul>
      </div>

      <!-- 会社情報 -->
      <div class="footer-col">
        <p class="footer-col-heading">会社情報</p>
        <ul>
          <li><a href="/about">Optiensについて</a></li>
          <li><a href="/hydroponics">IoT水耕栽培</a></li>
          <li><a href="/roadmap">ロードマップ</a></li>
          <li><a href="/contact">お問い合わせ</a></li>
        </ul>
      </div>

      <!-- リソース -->
      <div class="footer-col">
        <p class="footer-col-heading">リソース</p>
        <ul>
          <li><a href="/blog">ブログ</a></li>
          <li><a href="/privacy-policy">プライバシーポリシー</a></li>
          <li><a href="/site-policy">サイトポリシー</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">&copy; {new Date().getFullYear()} Optiens. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--surface);
    color: var(--text);
    padding: 56px 0 28px;
    font-size: 0.88em;
    margin-top: auto;
    border-top: 1px solid var(--border);
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ---------- Top: 4 columns ---------- */
  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--border);
  }

  /* Brand column */
  .footer-brand-col { display: flex; flex-direction: column; gap: 10px; }
  .footer-badge-link {
    display: inline-block;
    margin-top: 4px;
    transition: opacity .2s;
  }
  .footer-badge-link:hover { opacity: .8; }
  .footer-badge {
    width: 80px;
    height: auto;
  }
  .footer-tagline {
    margin: 0;
    color: var(--muted);
    font-size: .9em;
    line-height: 1.5;
  }
  .footer-email { margin: 0; }
  .footer-email a {
    color: var(--brand);
    text-decoration: none;
    font-size: .88em;
    transition: opacity .2s;
  }
  .footer-email a:hover { opacity: .8; }

  /* Link columns */
  .footer-col { display: flex; flex-direction: column; gap: 0; }
  .footer-col-heading {
    margin: 0 0 14px;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .12em;
    color: var(--heading);
    text-transform: uppercase;
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col a {
    color: var(--muted);
    text-decoration: none;
    font-size: .88rem;
    transition: color .2s;
  }
  .footer-col a:hover {
    color: var(--brand);
  }

  /* ---------- Bottom ---------- */
  .footer-bottom {
    padding-top: 24px;
    text-align: center;
  }
  .footer-copy {
    margin: 0;
    color: var(--muted);
    font-size: .78em;
    letter-spacing: .03em;
  }

  /* ---------- Mobile ---------- */
  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
      gap: 32px 24px;
    }
    .footer-brand-col {
      grid-column: 1 / -1;
      align-items: center;
      text-align: center;
    }
  }
  @media (max-width: 480px) {
    .footer-top {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer-col { align-items: center; }
    .footer-brand-col { align-items: center; }
  }
</style>
