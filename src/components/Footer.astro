<style>
  footer {
    background: var(--surface);
    color: var(--text);
    padding: 56px 0 28px;
    font-size: 0.88em;
    margin-top: auto;
    border-top: 1px solid var(--border);
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ---------- Sitemap: 3 columns ---------- */
  .footer-sitemap {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--border);
  }

  /* Link columns */
  .footer-col { display: flex; flex-direction: column; gap: 0; }
  .footer-col-heading {
    margin: 0 0 14px;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .12em;
    color: var(--heading);
    text-transform: uppercase;
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col a {
    color: var(--muted);
    text-decoration: none;
    font-size: .88rem;
    transition: color .2s;
  }
  .footer-col a:hover {
    color: var(--brand);
  }

  /* ---------- Brand row ---------- */
  .footer-brand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    padding: 32px 0;
    border-bottom: 1px solid var(--border);
  }
  .footer-badge-link {
    display: inline-block;
    transition: opacity .2s;
    flex-shrink: 0;
  }
  .footer-badge-link:hover { opacity: .8; }
  .footer-badge {
    width: 52px;
    height: auto;
  }
  .footer-brand-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .footer-tagline {
    margin: 0;
    color: var(--muted);
    font-size: .88em;
    line-height: 1.4;
  }
  .footer-email { margin: 0; }
  .footer-email a {
    color: var(--brand);
    text-decoration: none;
    font-size: .82em;
    transition: opacity .2s;
  }
  .footer-email a:hover { opacity: .8; }
  .footer-logo {
    width: 100px;
    height: auto;
    opacity: 0.6;
    flex-shrink: 0;
  }

  /* ---------- Bottom ---------- */
  .footer-bottom {
    padding-top: 24px;
    text-align: center;
  }
  .footer-copy {
    margin: 0;
    color: var(--muted);
    font-size: .78em;
    letter-spacing: .03em;
  }

  /* ---------- Mobile ---------- */
  @media (max-width: 768px) {
    .footer-sitemap {
      grid-template-columns: 1fr 1fr;
      gap: 32px 24px;
    }
    .footer-brand {
      flex-wrap: wrap;
      gap: 16px;
    }
  }
  @media (max-width: 480px) {
    .footer-sitemap {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer-col { align-items: center; }
    .footer-brand {
      flex-direction: column;
      text-align: center;
    }
    .footer-brand-text { align-items: center; }
  }
</style>
