---
---
<header class="main-header">
  <a href="/" class="header-logo-link">
    <img src="/images/optiens-logo.png" alt="Optiens" class="header-logo" />
  </a>

  <nav class="desktop-nav">
    <ul>
      <li><a href="/">HOME</a></li>
      <li><a href="/about">ABOUT</a></li>
      <li><a href="/ai-consulting">SERVICE</a></li>
      <li><a href="/hydroponics">HYDROPONICS</a></li>
      <li><a href="/blog">BLOG</a></li>
      <li><a href="/contact">CONTACT</a></li>
    </ul>
  </nav>

  <button id="menu-toggle" class="menu-button" aria-label="Toggle navigation">
    <span></span><span></span><span></span>
  </button>

  <nav id="sidebar-menu" class="sidebar-menu" aria-label="Mobile navigation">
    <ul>
      <li><a href="/">HOME</a></li>
      <li><a href="/about">ABOUT</a></li>
      <li><a href="/ai-consulting">SERVICE</a></li>
      <li><a href="/hydroponics">HYDROPONICS</a></li>
      <li><a href="/blog">BLOG</a></li>
      <li><a href="/contact">CONTACT</a></li>
    </ul>
  </nav>
</header>

<script is:inline>
  const menuToggle  = document.getElementById('menu-toggle');
  const sidebarMenu = document.getElementById('sidebar-menu');

  if (menuToggle && sidebarMenu) {
    menuToggle.addEventListener('click', () => {
      sidebarMenu.classList.toggle('is-open');
      menuToggle.classList.toggle('is-active');
    });

    sidebarMenu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        sidebarMenu.classList.remove('is-open');
        menuToggle.classList.remove('is-active');
      });
    });
  }
</script>

<style>
.main-header {
  width: 100%;
  background: rgba(10, 10, 10, .75);
  backdrop-filter: blur(16px) saturate(1.4);
  -webkit-backdrop-filter: blur(16px) saturate(1.4);
  color: var(--text);
  padding: 14px 40px;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 9900;
  border-bottom: 1px solid var(--border);
}
.header-logo { height: 44px; max-width: none; display: block; }

@media (min-width: 769px) {
  .main-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .header-logo-link {
    display: block;
    flex-shrink: 0;
  }
  .desktop-nav {
    margin-left: auto;
  }
  .desktop-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 36px;
  }
  .desktop-nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: .82rem;
    font-weight: 500;
    letter-spacing: .08em;
    transition: color .2s ease;
  }
  .desktop-nav a:hover {
    color: #fff;
  }
  .menu-button, .sidebar-menu { display: none; }
}

@media (max-width: 768px) {
  .main-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 16px;
  }
  .header-logo-link { position: static; display: block; }
  .header-logo { height: 36px; }

  .menu-button {
    position: static;
    z-index: 10001;
    width: 32px;
    height: 24px;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    padding: 0;
  }
  .menu-button span {
    display: block;
    width: 100%;
    height: 2px;
    background: #fff;
    transition: all .3s ease-in-out;
    border-radius: 2px;
  }
  .menu-button.is-active span:nth-child(1) { transform: translateY(11px) rotate(45deg); }
  .menu-button.is-active span:nth-child(2) { opacity: 0; }
  .menu-button.is-active span:nth-child(3) { transform: translateY(-11px) rotate(-45deg); }

  .sidebar-menu {
    position: fixed;
    top: 0;
    right: -280px;
    width: 280px;
    height: 100vh;
    background: rgba(10, 10, 14, .96);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    color: #fff;
    transition: right .3s ease-out;
    z-index: 10000;
    padding-top: 80px;
    border-left: 1px solid var(--border);
    overflow-y: auto;
  }
  .sidebar-menu.is-open { right: 0; }

  .sidebar-menu ul { list-style: none; padding: 0; margin: 0; }
  .sidebar-menu li { border-bottom: 1px solid var(--border); }
  .sidebar-menu a {
    display: block;
    padding: 16px 24px;
    color: var(--text);
    font-size: .92rem;
    font-weight: 500;
    letter-spacing: .06em;
    text-decoration: none;
    transition: background-color .2s ease, color .2s ease;
  }
  .sidebar-menu a:hover,
  .sidebar-menu a:active {
    background-color: rgba(91, 127, 255, .08);
    color: var(--brand);
  }
  .desktop-nav { display: none; }
}

/* Progress bar / line fix */
#nprogress, #nprogress .bar,
.pace, .pace .pace-progress,
.top-loader, .top-progress, .router-progress-bar,
progress[role="progressbar"] { display: none !important; }

.main-header::before {
  content: "";
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 2px;
  background: rgba(10, 10, 10, .75);
  pointer-events: none;
  z-index: 9800;
}
.main-header, .main-header::before {
  transform: translateZ(0);
  -webkit-font-smoothing: antialiased;
}
</style>
